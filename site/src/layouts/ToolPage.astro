---
import Layout from './Layout.astro';
import Share from '../components/Share.astro';
import PathNav from '../components/PathNav.astro';
import ReadingEnhancers from '../components/ReadingEnhancers.astro';
import { TOOLS } from '../data/tools.js';
import { AI } from '../data/ai.js';
import { REFERENCE } from '../data/reference.js';
import { TOOL_GRAPH } from '../data/toolGraph.js';

const { title, description, path, eyebrow, h1, tagline } = Astro.props;

// resolve any href to a label/description so the graph block can render real names
const resolve = {};
TOOLS.forEach(t => { if (t.href) resolve[t.href] = { href: t.href, label: t.nm, ds: t.ds, kind: 'Tool' }; });
AI.forEach(a => { resolve[a.href] = { href: a.href, label: a.nm, ds: a.ds, kind: 'Concept' }; });
REFERENCE.forEach(r => { resolve[r.href] = { href: r.href, label: r.nm, ds: r.ds, kind: 'Knowledge Base' }; });

const g = TOOL_GRAPH[path];
const learn = g ? g.learn.map(h => resolve[h]).filter(Boolean) : [];
const related = g ? g.related.map(h => resolve[h]).filter(Boolean) : [];
const next = g && g.next ? resolve[g.next] : null;
// tools with no graph entry fall back to category siblings
const siblings = !g ? TOOLS.filter(t => t.href && t.href !== path).slice(0, 4) : [];
---
<Layout title={title} description={description} path={path} sidebar={true} crumb={[{label:'Tools', href:'/tools'}, {label: h1}]}>

  <header class="tool-head">
    <div class="eyebrow">{eyebrow}</div>
    <h1>{h1}</h1>
    <p class="tagline">{tagline}</p>
  </header>
  <div id="pn-top"></div>

  <section class="tool-stage">
    <slot />
  </section>

  <Share path={path} title={h1} variant="prominent" />

  <section class="prose">
    <slot name="explainer" />
  </section>

  <div id="pn-bottom"></div>
  <PathNav />

  {g ? (
    <aside class="tgraph">
      {next && (
        <a class="tg-next" href={next.href}>
          <span class="tg-next-lbl">Next step</span>
          <span class="tg-next-nm">{next.label} <span aria-hidden="true">→</span></span>
          <span class="tg-next-ds">{next.ds}</span>
        </a>
      )}
      <div class="tg-cols">
        {learn.length > 0 && (
          <div class="tg-col">
            <h3>Learn the concept</h3>
            {learn.map(x => (
              <a class="tg-link" href={x.href}><span class="tg-k tg-concept">Concept</span><span class="tg-nm">{x.label}</span></a>
            ))}
          </div>
        )}
        {related.length > 0 && (
          <div class="tg-col">
            <h3>Related tools</h3>
            {related.map(x => (
              <a class="tg-link" href={x.href}><span class="tg-k tg-tool">Tool</span><span class="tg-nm">{x.label}</span></a>
            ))}
          </div>
        )}
      </div>
      <a class="tg-all" href="/tools?cat=ai">Browse all AI tools →</a>
    </aside>
  ) : (
    <aside class="siblings">
      <h2>More on the menu</h2>
      <div class="sib-grid">
        {siblings.map(t => (
          <a class="sib" href={t.href}>
            <span class="sib-ct">{t.ctl}</span>
            <span class="sib-nm">{t.nm}</span>
            <span class="sib-ds">{t.ds}</span>
          </a>
        ))}
      </div>
    </aside>
  )}

  {next && (
    <div class="postcopy" id="postcopy" hidden>
      <span class="pc-check">✓</span>
      <span class="pc-txt">Copied. Next step: <a href={next.href}>{next.label} <span aria-hidden="true">→</span></a></span>
      <button class="pc-x" id="pc-x" type="button" aria-label="Dismiss">✕</button>
    </div>
  )}
  <script is:inline>
    (function () {
      var pc = document.getElementById('postcopy'); if (!pc) return;
      var timer;
      function hide() { pc.classList.remove('show'); setTimeout(function () { pc.hidden = true; }, 280); }
      document.addEventListener('click', function (e) {
        if (!e.target.closest('.btn-copy')) return;
        pc.hidden = false; void pc.offsetWidth; pc.classList.add('show');
        clearTimeout(timer); timer = setTimeout(hide, 5500);
      });
      var x = document.getElementById('pc-x'); if (x) x.addEventListener('click', hide);
    })();
  </script>
  <script is:inline>
    // analytics: "Tool Used" fires once per page on the first real interaction
    // (a primary button, a copy button, or a sample chip), covering every tool.
    (function () {
      var fired = false;
      document.addEventListener('click', function (e) {
        if (fired || !e.target.closest('.btn, .btn-copy, .chip')) return;
        fired = true;
        window.kbTrack && window.kbTrack('Tool Used', { tool: location.pathname.replace(/^\/+/, '') });
      });
    })();
  </script>
  <ReadingEnhancers />
</Layout>

<style is:global>
  .crumb{font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);padding:20px 0 0;display:flex;gap:8px;flex-wrap:wrap}
  .crumb a{color:var(--ink-soft);text-decoration:none}
  .crumb a:hover{color:var(--coral)}
  .crumb em{color:var(--ink);font-style:normal}
  .crumb span{opacity:.5}

  .tool-head{padding:30px 0 26px;max-width:760px}
  .tool-head .eyebrow{font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--coral);margin-bottom:14px}
  .tool-head h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;line-height:1;font-size:clamp(34px,5.4vw,52px)}
  .tool-head .tagline{margin-top:16px;font-size:18px;color:var(--ink-soft);line-height:1.5;max-width:600px}

  /* shared tool UI primitives */
  .tool-stage{margin-bottom:30px}
  .panes{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .pane{display:flex;flex-direction:column;gap:9px}
  .pane-label{display:flex;align-items:center;justify-content:space-between;font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft)}
  .ta{width:100%;min-height:320px;resize:vertical;border:1.5px solid var(--ink);border-radius:14px;background:var(--cream);
    font-family:var(--font-mono);font-size:13.5px;line-height:1.55;color:var(--ink);padding:15px 16px;outline:0;tab-size:2}
  .ta:focus{box-shadow:6px 6px 0 var(--coral)}
  .ta[readonly]{background:var(--paper-2)}
  .ta.err{border-color:var(--coral-deep);box-shadow:6px 6px 0 rgba(214,62,31,.25)}

  .btn{font-family:var(--font-display);font-weight:700;font-size:14px;color:var(--cream);background:var(--coral);
    border:0;border-radius:11px;padding:11px 18px;cursor:pointer;transition:background .15s,transform .12s}
  .btn:hover{background:var(--coral-deep)} .btn:active{transform:scale(.97)}
  .btn.ghost{background:transparent;color:var(--ink);border:1.5px solid var(--line)}
  .btn.ghost:hover{border-color:var(--ink);background:transparent}
  /* big copy button for a tool's final output */
  .btn-copy{display:inline-flex;align-items:center;justify-content:center;gap:9px;width:100%;
    font-family:var(--font-display);font-weight:800;font-size:16px;color:#fff;
    background:linear-gradient(135deg,#ff5839,#e23a1d);border:0;border-radius:14px;padding:15px 22px;cursor:pointer;
    box-shadow:0 10px 24px rgba(226,58,29,.26);transition:transform .14s,box-shadow .14s}
  .btn-copy:hover{transform:translateY(-2px);box-shadow:0 16px 32px rgba(226,58,29,.32)}
  .btn-copy:active{transform:scale(.99)}
  .btn-copy.done{background:linear-gradient(135deg,#16a37e,#0f8a69);box-shadow:0 10px 24px rgba(15,159,130,.26)}
  .btn-copy svg{width:19px;height:19px}
  /* post-copy "next step" toast */
  .postcopy{position:fixed;left:50%;bottom:24px;transform:translate(-50%,16px);z-index:50;
    display:flex;align-items:center;gap:11px;max-width:calc(100vw - 32px);
    background:linear-gradient(135deg,#1c1410,#241813);color:#fff;border-radius:14px;padding:13px 16px;
    box-shadow:0 18px 44px rgba(16,17,18,.3);font-family:var(--font-body);font-size:14px;
    opacity:0;pointer-events:none;transition:opacity .28s,transform .28s}
  .postcopy.show{opacity:1;transform:translate(-50%,0);pointer-events:auto}
  .pc-check{display:grid;place-items:center;width:22px;height:22px;border-radius:50%;background:#16a37e;color:#fff;font-size:13px;font-weight:800;flex-shrink:0}
  .pc-txt{color:rgba(255,255,255,.82)}
  .pc-txt a{color:#ff7a5c;font-family:var(--font-display);font-weight:800;text-decoration:none;white-space:nowrap}
  .pc-txt a:hover{color:#fff}
  .pc-x{background:none;border:0;color:rgba(255,255,255,.5);cursor:pointer;font-size:13px;padding:0 2px;flex-shrink:0}
  .pc-x:hover{color:#fff}
  .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}

  .chip{font-family:var(--font-mono);font-size:12px;font-weight:500;color:var(--ink-soft);background:transparent;
    border:1px solid var(--line);border-radius:18px;padding:7px 13px;cursor:pointer;transition:all .15s}
  .chip:hover{border-color:var(--ink);color:var(--ink)}
  .chip.active{background:var(--ink);color:var(--cream);border-color:var(--ink)}

  .status{font-family:var(--font-mono);font-size:12px;min-height:18px}
  .status.ok{color:#2f7d32} .status.bad{color:var(--coral-deep)}

  /* prose / explainer */
  .prose{max-width:740px;padding:34px 0 8px;border-top:1px solid var(--line);margin-top:18px}
  .prose h2{font-family:var(--font-display);font-weight:800;font-size:26px;letter-spacing:-.02em;margin:30px 0 12px}
  .prose h2:first-child{margin-top:0}
  .prose h3{font-family:var(--font-display);font-weight:700;font-size:18px;margin:22px 0 8px}
  .prose p{font-size:16px;line-height:1.65;color:var(--ink-soft);margin:0 0 14px}
  .prose ul{margin:0 0 16px;padding-left:22px}
  .prose li{font-size:16px;line-height:1.6;color:var(--ink-soft);margin-bottom:7px}
  .prose code{font-family:var(--font-mono);font-size:13.5px;background:var(--paper-2);padding:2px 6px;border-radius:6px;color:var(--ink)}
  .prose a{color:var(--coral);font-weight:600;text-decoration:none}
  .prose a:hover{text-decoration:underline}
  .prose .faq{border:1px solid var(--line);border-radius:14px;padding:4px 18px;margin-bottom:10px;background:var(--cream)}
  .prose .faq summary{font-family:var(--font-display);font-weight:700;font-size:16px;padding:14px 0;cursor:pointer;list-style:none}
  .prose .faq summary::-webkit-details-marker{display:none}
  .prose .faq[open] summary{color:var(--coral)}
  .prose .faq p{margin:0 0 14px}
  /* ── shared flagship elements (TOC, code, comparison table, Classic block) ── */
  .toc{display:flex;flex-wrap:wrap;gap:6px 14px;align-items:center;margin:6px 0 26px;padding:14px 16px;border:1.2px solid var(--line);border-radius:13px;background:var(--paper-2)}
  .toc-h{font-family:var(--font-mono);font-size:10.5px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);margin-right:4px}
  .toc a{font-family:var(--font-mono);font-size:12.5px;color:var(--coral);text-decoration:none;font-weight:600}
  .toc a:hover{text-decoration:underline}
  .prose .code{background:#1e1813;color:#f4e9d6;border-radius:12px;padding:15px 16px;overflow-x:auto;margin:10px 0 14px;border:1px solid rgba(255,255,255,.08)}
  .prose .code code{font-family:var(--font-mono);font-size:13px;line-height:1.6;white-space:pre;color:inherit;background:none;padding:0}
  .prose .cmp{width:100%;border-collapse:collapse;margin:12px 0 6px;font-size:14px;display:table}
  .prose .cmp th,.prose .cmp td{border:1px solid var(--line);padding:9px 12px;text-align:left;vertical-align:top}
  .prose .cmp thead th{font-family:var(--font-mono);font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);background:var(--paper-2)}
  .prose .cmp td:first-child{font-weight:700;color:var(--ink);width:150px}
  .prose .cmp code{font-size:12.5px}
  .classic{margin:30px 0 0;padding:16px 18px;border:1.5px solid rgba(244,132,42,.32);border-radius:14px;background:rgba(244,180,35,.1)}
  .classic-tag{font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#9a5b00}
  .classic p{margin:9px 0 0;font-size:14px;line-height:1.6;color:var(--ink-soft)}

  .siblings{padding:36px 0 10px;border-top:1px solid var(--line);margin-top:26px}
  .siblings h2{font-family:var(--font-display);font-weight:800;font-size:22px;margin-bottom:16px}
  .sib-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  .sib{display:flex;flex-direction:column;gap:5px;text-decoration:none;color:inherit;background:var(--cream);
    border:1.5px solid var(--line);border-radius:14px;padding:15px 15px 17px;transition:transform .15s,box-shadow .15s,border-color .15s}
  .sib:hover{transform:translateY(-3px);box-shadow:7px 8px 0 rgba(30,24,19,.08);border-color:var(--ink)}
  .sib-ct{font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--coral)}
  .sib-nm{font-family:var(--font-mono);font-weight:700;font-size:15px}
  .sib-ds{font-size:12.5px;color:var(--ink-soft);line-height:1.4}

  /* knowledge-graph cross-nav */
  .tgraph{padding:32px 0 10px;border-top:1px solid var(--line);margin-top:26px}
  .tg-next{display:flex;flex-direction:column;gap:3px;text-decoration:none;color:#fff;border-radius:18px;padding:18px 22px;margin-bottom:22px;
    background:radial-gradient(circle at 90% 30%,rgba(238,75,43,.28),transparent 40%),linear-gradient(135deg,#1c1410,#241813);
    box-shadow:0 16px 40px rgba(16,17,18,.18);transition:transform .16s,box-shadow .16s}
  .tg-next:hover{transform:translateY(-2px);box-shadow:0 22px 50px rgba(16,17,18,.24)}
  .tg-next-lbl{font-family:var(--font-mono);font-size:10px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--gold)}
  .tg-next-nm{font-family:var(--font-display);font-weight:800;font-size:20px;letter-spacing:-.02em}
  .tg-next-ds{font-size:13.5px;color:rgba(255,255,255,.72)}
  .tg-cols{display:grid;grid-template-columns:1fr 1fr;gap:26px}
  .tg-col h3{font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin:0 0 12px}
  .tg-link{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--ink);padding:9px 0;border-bottom:1px solid var(--line)}
  .tg-link:last-child{border-bottom:0}
  .tg-link:hover .tg-nm{color:var(--coral)}
  .tg-k{font-family:var(--font-mono);font-size:9.5px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;padding:3px 7px;border-radius:5px;flex-shrink:0}
  .tg-concept{background:#efe8ff;color:#6a4dff} .tg-tool{background:#ffe5dd;color:var(--coral-deep)}
  .tg-nm{font-family:var(--font-display);font-weight:700;font-size:14.5px;transition:color .14s}
  .tg-all{display:inline-block;margin-top:22px;font-family:var(--font-display);font-weight:800;font-size:14px;color:var(--ink);text-decoration:none}
  .tg-all:hover{color:var(--coral)}

  @media(max-width:760px){.panes{grid-template-columns:1fr}.sib-grid{grid-template-columns:1fr 1fr}.tg-cols{grid-template-columns:1fr;gap:20px}}
  @media(max-width:480px){.sib-grid{grid-template-columns:1fr}}
</style>
