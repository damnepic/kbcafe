---
import Layout from './Layout.astro';
import Share from '../components/Share.astro';
import ReadingEnhancers from '../components/ReadingEnhancers.astro';
import { POSTS, fmtDate } from '../data/blog.js';

const { title, description, slug, tag, date } = Astro.props;
const path = `/blog/${slug}`;
const others = POSTS.filter(p => p.slug !== slug).slice(0, 3);
---
<Layout title={`${title} | KB Cafe Blog`} description={description} path={path} sidebar={true} crumb={[{label:'Blog', href:'/blog'}, {label: title}]}>

  <article class="post">
    <header class="post-head">
      <div class="post-meta"><span class="tag">{tag}</span> · <time>{fmtDate(date)}</time></div>
      <h1>{title}</h1>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <Share path={path} title={title} variant="subtle" lead="general" />

  <aside class="siblings">
    <h2>More from the blog</h2>
    <div class="sib-grid">
      {others.map(p => (
        <a class="sib" href={`/blog/${p.slug}`}>
          <span class="sib-ct">{p.tag} · {fmtDate(p.date)}</span>
          <span class="sib-nm">{p.title}</span>
          <span class="sib-ds">{p.excerpt}</span>
        </a>
      ))}
    </div>
  </aside>

  <ReadingEnhancers />
</Layout>

<style is:global>
  .post{max-width:720px}
  .post-head{padding:26px 0 18px}
  .post-meta{font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px}
  .post-meta .tag{color:var(--coral)}
  .post-head h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;line-height:1.04;font-size:clamp(32px,5.4vw,52px)}
  /* prose/crumb/siblings shared with ReferencePage's global block; redefined for standalone render */
  .crumb{font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);padding:20px 0 0;display:flex;gap:8px;flex-wrap:wrap}
  .crumb a{color:var(--ink-soft);text-decoration:none}.crumb a:hover{color:var(--coral)}
  .crumb em{color:var(--ink);font-style:normal}.crumb span{opacity:.5}
  .prose h2{font-family:var(--font-display);font-weight:800;font-size:25px;letter-spacing:-.02em;margin:30px 0 12px}
  .prose h2:first-child{margin-top:6px}
  .prose h3{font-family:var(--font-display);font-weight:700;font-size:18px;margin:22px 0 8px}
  .prose p{font-size:16.5px;line-height:1.72;color:var(--ink-soft);margin:0 0 15px}
  .prose ul,.prose ol{margin:0 0 16px;padding-left:24px}
  .prose li{font-size:16.5px;line-height:1.65;color:var(--ink-soft);margin-bottom:8px}
  .prose code{font-family:var(--font-mono);font-size:14px;background:var(--paper-2);padding:2px 6px;border-radius:6px;color:var(--ink)}
  .prose strong{color:var(--ink)}
  .prose a{color:var(--coral);font-weight:600;text-decoration:none}.prose a:hover{text-decoration:underline}
  .prose blockquote{border-left:3px solid var(--gold);padding:2px 0 2px 18px;margin:0 0 16px;font-family:var(--font-display);font-weight:600;font-size:19px;color:var(--ink);line-height:1.4}
  .siblings{padding:36px 0 10px;border-top:1px solid var(--line);margin-top:30px}
  .siblings h2{font-family:var(--font-display);font-weight:800;font-size:22px;margin-bottom:16px}
  .sib-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .sib{display:flex;flex-direction:column;gap:5px;text-decoration:none;color:inherit;background:var(--cream);border:1.5px solid var(--line);border-radius:14px;padding:15px 15px 17px;transition:transform .15s,box-shadow .15s,border-color .15s}
  .sib:hover{transform:translateY(-3px);box-shadow:7px 8px 0 rgba(30,24,19,.08);border-color:var(--ink)}
  .sib-ct{font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--coral)}
  .sib-nm{font-family:var(--font-mono);font-weight:700;font-size:15px;line-height:1.15}
  .sib-ds{font-size:12.5px;color:var(--ink-soft);line-height:1.4}
  @media(max-width:680px){.sib-grid{grid-template-columns:1fr}}
  .post .prose figure{margin:26px 0}
  .post .prose figure img{display:block;width:100%;height:auto;border:1.5px solid var(--line);border-radius:14px;box-shadow:0 12px 30px rgba(30,24,19,.09)}
  .post .prose figure.tight{max-width:520px;margin-inline:auto}
  .post .prose figcaption{margin-top:10px;font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);text-align:center;line-height:1.55}
</style>
