---
import Layout from './Layout.astro';
import Share from '../components/Share.astro';
import ReadingEnhancers from '../components/ReadingEnhancers.astro';
import { REFERENCE } from '../data/reference.js';
import { TOOLS } from '../data/tools.js';

const { title, description, path, eyebrow, h1, tagline, updated = '2026' } = Astro.props;

// Curated "Continue learning" links (references + a relevant tool/hub), resolved
// to display metadata. Falls back to nearby references if a page has no `rel`.
const STATIC = {
  '/feeds': { nm: 'RSS, Atom & OPML, the complete guide', tag: 'Feeds' },
  '/reference': { nm: 'All developer references', tag: 'Knowledge Base' },
};
const metaFor = (href) => {
  const r = REFERENCE.find(x => x.href === href);
  if (r) return { href, nm: r.nm, tag: r.tag, ds: r.ds };
  const t = TOOLS.find(x => x.href === href);
  if (t) return { href, nm: t.nm, tag: 'Tool', ds: t.ds || '' };
  if (STATIC[href]) return { href, ...STATIC[href], ds: '' };
  return { href, nm: href, tag: '', ds: '' };
};
const cur = REFERENCE.find(r => r.href === path);
const related = (cur && cur.rel ? cur.rel : []).map(metaFor);
const others = REFERENCE.filter(r => r.href !== path).slice(0, 3);
const guides = related.length ? related : others;
---
<Layout title={title} description={description} path={path} sidebar={true} crumb={[{label:'Knowledge Base', href:'/reference'}, {label: h1}]}>

  <article class="ref-article">
    <header class="ref-head">
      <div class="eyebrow">{eyebrow}</div>
      <h1>{h1}</h1>
      <p class="tagline">{tagline}</p>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>

  <Share path={path} title={h1} variant="subtle" />

  <aside class="siblings related-guides">
    <div class="rg-head">
      <h2>Continue learning</h2>
      <a class="rg-all" href="/reference">All references &rarr;</a>
    </div>
    <div class="sib-grid">
      {guides.map(g => (
        <a class="sib" href={g.href}>
          <span class="sib-ct">{g.tag}</span>
          <span class="sib-nm">{g.nm}</span>
          <span class="sib-ds">{g.ds}</span>
        </a>
      ))}
    </div>
  </aside>

  <ReadingEnhancers />
</Layout>

<style is:global>
  .ref-article{max-width:740px}
  .ref-head{padding:28px 0 22px}
  .ref-head .eyebrow{font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--coral);margin-bottom:14px}
  .ref-head h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;line-height:1.02;font-size:clamp(32px,5vw,48px)}
  .ref-head .tagline{margin-top:16px;font-size:18px;color:var(--ink-soft);line-height:1.5}
  /* .prose, .crumb, .siblings styles are shared from ToolPage's global block when present;
     redefine here so reference pages render standalone. */
  .crumb{font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);padding:20px 0 0;display:flex;gap:8px;flex-wrap:wrap}
  .crumb a{color:var(--ink-soft);text-decoration:none}.crumb a:hover{color:var(--coral)}
  .crumb em{color:var(--ink);font-style:normal}.crumb span{opacity:.5}
  .prose h2{font-family:var(--font-display);font-weight:800;font-size:26px;letter-spacing:-.02em;margin:30px 0 12px}
  .prose h2:first-child{margin-top:4px}
  .prose h3{font-family:var(--font-display);font-weight:700;font-size:19px;margin:24px 0 9px}
  .prose p{font-size:16.5px;line-height:1.7;color:var(--ink-soft);margin:0 0 15px}
  .prose ul,.prose ol{margin:0 0 16px;padding-left:24px}
  .prose li{font-size:16.5px;line-height:1.65;color:var(--ink-soft);margin-bottom:8px}
  .prose code{font-family:var(--font-mono);font-size:14px;background:var(--paper-2);padding:2px 6px;border-radius:6px;color:var(--ink)}
  .prose strong{color:var(--ink)}
  .prose a{color:var(--coral);font-weight:600;text-decoration:none}.prose a:hover{text-decoration:underline}
  .prose .faq{border:1px solid var(--line);border-radius:14px;padding:4px 18px;margin-bottom:10px;background:var(--cream)}
  .prose .faq summary{font-family:var(--font-display);font-weight:700;font-size:16px;padding:14px 0;cursor:pointer;list-style:none}
  .prose .faq summary::-webkit-details-marker{display:none}
  .prose .faq[open] summary{color:var(--coral)}
  /* ── shared flagship elements (TOC, code, comparison table, Classic block) ── */
  .toc{display:flex;flex-wrap:wrap;gap:6px 14px;align-items:center;margin:6px 0 26px;padding:14px 16px;border:1.2px solid var(--line);border-radius:13px;background:var(--paper-2)}
  .toc-h{font-family:var(--font-mono);font-size:10.5px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);margin-right:4px}
  .toc a{font-family:var(--font-mono);font-size:12.5px;color:var(--coral);text-decoration:none;font-weight:600}
  .toc a:hover{text-decoration:underline}
  .prose .code{background:#1e1813;color:#f4e9d6;border-radius:12px;padding:15px 16px;overflow-x:auto;margin:10px 0 14px;border:1px solid rgba(255,255,255,.08)}
  .prose .code code{font-family:var(--font-mono);font-size:13px;line-height:1.6;white-space:pre;color:inherit;background:none;padding:0}
  .prose .cmp{width:100%;border-collapse:collapse;margin:12px 0 6px;font-size:14px;display:table}
  .prose .cmp th,.prose .cmp td{border:1px solid var(--line);padding:9px 12px;text-align:left;vertical-align:top}
  .prose .cmp thead th{font-family:var(--font-mono);font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);background:var(--paper-2)}
  .prose .cmp td:first-child{font-weight:700;color:var(--ink);width:150px}
  .prose .cmp code{font-size:12.5px}
  .classic{margin:30px 0 0;padding:16px 18px;border:1.5px solid rgba(244,132,42,.32);border-radius:14px;background:rgba(244,180,35,.1)}
  .classic-tag{font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#9a5b00}
  .classic p{margin:9px 0 0;font-size:14px;line-height:1.6;color:var(--ink-soft)}
  .siblings{padding:36px 0 10px;border-top:1px solid var(--line);margin-top:30px}
  .siblings h2{font-family:var(--font-display);font-weight:800;font-size:22px;margin-bottom:16px}
  .rg-head{display:flex;align-items:baseline;justify-content:space-between;gap:14px;margin-bottom:16px}
  .rg-head h2{margin-bottom:0}
  .rg-all{font-family:var(--font-display);font-weight:800;font-size:13.5px;color:var(--ink);text-decoration:none;white-space:nowrap}
  .rg-all:hover{color:var(--coral)}
  .sib-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .sib{display:flex;flex-direction:column;gap:5px;text-decoration:none;color:inherit;background:var(--cream);border:1.5px solid var(--line);border-radius:14px;padding:15px 15px 17px;transition:transform .15s,box-shadow .15s,border-color .15s}
  .sib:hover{transform:translateY(-3px);box-shadow:7px 8px 0 rgba(30,24,19,.08);border-color:var(--ink)}
  .sib-ct{font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--coral)}
  .sib-nm{font-family:var(--font-mono);font-weight:700;font-size:15px;line-height:1.15}
  .sib-ds{font-size:12.5px;color:var(--ink-soft);line-height:1.4}
  @media(max-width:680px){.sib-grid{grid-template-columns:1fr}}
</style>
