---
import Layout from './Layout.astro';
import Share from '../components/Share.astro';
import PathNav from '../components/PathNav.astro';
import { AI, titleFor } from '../data/ai.js';
import { TOOLS } from '../data/tools.js';
import { TOOL_GRAPH } from '../data/toolGraph.js';
import { pathsWith } from '../data/learningPaths.js';

const { title, description, path, eyebrow, h1, tagline } = Astro.props;
const others = AI.filter(a => a.href !== path && a.type === 'explainer').slice(0, 3);

const rel = AI.find(a => a.href === path)?.rel || {};
const graphRows = [
  { label: 'Prerequisites', items: rel.prereq || [] },
  { label: 'Related', items: rel.related || [] },
  { label: 'Next', items: rel.next || [] },
].filter(r => r.items.length);

// reverse edges: tools that teach/use this concept, and paths it appears in
const toolLabel = Object.fromEntries(TOOLS.filter(t => t.href).map(t => [t.href, t.nm]));
const tryTools = Object.keys(TOOL_GRAPH).filter(h => (TOOL_GRAPH[h].learn || []).includes(path));
const appearsIn = pathsWith(path);
---
<Layout title={title} description={description} path={path} sidebar={true} crumb={[{label:'AI Explained', href:'/ai'}, {label: h1}]}>

  <article class="ref-article">
    <header class="ref-head">
      <div class="eyebrow">{eyebrow}</div>
      <h1 set:html={h1} />
      <p class="tagline">{tagline}</p>
    </header>
    <div id="pn-top"></div>
    <div class="prose">
      <slot />
    </div>
  </article>

  <div id="pn-bottom"></div>

  <Share path={path} title={h1} variant="subtle" />
  <PathNav />

  {graphRows.length > 0 && (
    <nav class="kgraph" aria-label="Related concepts">
      <div class="kg-title">Related concepts</div>
      {graphRows.map(row => (
        <div class="kg-row">
          <span class="kg-lbl">{row.label}</span>
          <span class="kg-links">
            {row.items.map(href => <a href={href} set:html={titleFor(href)} />)}
          </span>
        </div>
      ))}
    </nav>
  )}

  {(tryTools.length > 0 || appearsIn.length > 0) && (
    <nav class="kgraph practice" aria-label="Put it into practice">
      <div class="kg-title kg-practice">Put it into practice</div>
      {tryTools.length > 0 && (
        <div class="kg-row">
          <span class="kg-lbl">Try it</span>
          <span class="kg-links tools">{tryTools.map(h => <a href={h}>{toolLabel[h] || h}</a>)}</span>
        </div>
      )}
      {appearsIn.length > 0 && (
        <div class="kg-row">
          <span class="kg-lbl">Appears in</span>
          <span class="kg-links paths">{appearsIn.map(p => <a href={p.route}>{p.title} path</a>)}</span>
        </div>
      )}
      <a class="kg-map" href="/map">See the whole knowledge map →</a>
    </nav>
  )}

  <aside class="siblings">
    <h2>More from AI Explained</h2>
    <div class="sib-grid">
      {others.map(a => (
        <a class="sib" href={a.href}>
          <span class="sib-ct">{a.tag}</span>
          <span class="sib-nm" set:html={a.nm} />
          <span class="sib-ds">{a.ds}</span>
        </a>
      ))}
    </div>
  </aside>
</Layout>

<style is:global>
  /* reuses the same prose/crumb/siblings system as ReferencePage */
  .ref-article{max-width:740px}
  .ref-head{padding:28px 0 22px}
  .ref-head .eyebrow{font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--coral);margin-bottom:14px}
  .ref-head h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;line-height:1.02;font-size:clamp(32px,5vw,48px)}
  .ref-head .tagline{margin-top:16px;font-size:18px;color:var(--ink-soft);line-height:1.5}
  .crumb{font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);padding:20px 0 0;display:flex;gap:8px;flex-wrap:wrap}
  .crumb a{color:var(--ink-soft);text-decoration:none}.crumb a:hover{color:var(--coral)}
  .crumb em{color:var(--ink);font-style:normal}.crumb span{opacity:.5}
  .prose h2{font-family:var(--font-display);font-weight:800;font-size:26px;letter-spacing:-.02em;margin:30px 0 12px}
  .prose h2:first-child{margin-top:4px}
  .prose h3{font-family:var(--font-display);font-weight:700;font-size:19px;margin:24px 0 9px}
  .prose p{font-size:16.5px;line-height:1.7;color:var(--ink-soft);margin:0 0 15px}
  .prose ul,.prose ol{margin:0 0 16px;padding-left:24px}
  .prose li{font-size:16.5px;line-height:1.65;color:var(--ink-soft);margin-bottom:8px}
  .prose code{font-family:var(--font-mono);font-size:14px;background:var(--paper-2);padding:2px 6px;border-radius:6px;color:var(--ink)}
  .prose strong{color:var(--ink)}
  .prose a{color:var(--coral);font-weight:600;text-decoration:none}.prose a:hover{text-decoration:underline}
  .prose .faq{border:1px solid var(--line);border-radius:14px;padding:4px 18px;margin-bottom:10px;background:var(--cream)}
  .prose .faq summary{font-family:var(--font-display);font-weight:700;font-size:16px;padding:14px 0;cursor:pointer;list-style:none}
  .prose .faq summary::-webkit-details-marker{display:none}
  .prose .faq[open] summary{color:var(--coral)}
  .prose .note{font-size:13.5px;color:var(--ink-soft);background:var(--paper-2);border-radius:10px;padding:11px 14px;margin:0 0 16px}
  .kgraph{margin-top:34px;background:var(--cream);border:1.5px solid var(--line);border-radius:16px;padding:18px 20px}
  .kg-title{font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--coral);margin-bottom:12px}
  .kg-row{display:flex;gap:14px;align-items:baseline;padding:7px 0;border-top:1px solid var(--line)}
  .kg-row:first-of-type{border-top:0}
  .kg-lbl{font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);width:108px;flex-shrink:0}
  .kg-links{display:flex;flex-wrap:wrap;gap:8px 16px}
  .kg-links a{font-family:var(--font-mono);font-size:13.5px;font-weight:600;color:var(--ink);text-decoration:none;border-bottom:1.5px solid var(--gold)}
  .kg-links a:hover{color:var(--coral);border-color:var(--coral)}
  .kgraph.practice{margin-top:14px}
  .kg-practice{color:#0f9f82}
  .kg-links.tools a{border-color:var(--coral)} .kg-links.paths a{border-color:var(--ink)}
  .kg-map{display:inline-block;margin-top:14px;font-family:var(--font-display);font-weight:800;font-size:13px;color:var(--ink);text-decoration:none}
  .kg-map:hover{color:var(--coral)}
  .siblings{padding:36px 0 10px;border-top:1px solid var(--line);margin-top:30px}
  .siblings h2{font-family:var(--font-display);font-weight:800;font-size:22px;margin-bottom:16px}
  .sib-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .sib{display:flex;flex-direction:column;gap:5px;text-decoration:none;color:inherit;background:var(--cream);border:1.5px solid var(--line);border-radius:14px;padding:15px 15px 17px;transition:transform .15s,box-shadow .15s,border-color .15s}
  .sib:hover{transform:translateY(-3px);box-shadow:7px 8px 0 rgba(30,24,19,.08);border-color:var(--ink)}
  .sib-ct{font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--coral)}
  .sib-nm{font-family:var(--font-mono);font-weight:700;font-size:15px;line-height:1.15}
  .sib-ds{font-size:12.5px;color:var(--ink-soft);line-height:1.4}
  @media(max-width:680px){.sib-grid{grid-template-columns:1fr}}
</style>
