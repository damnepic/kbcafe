---
import ToolPage from '../layouts/ToolPage.astro';
// NOTE: source recovered + cleaned from build output 2026-06-20. UI + explainer are inline markup.
---
<ToolPage
  title="WHOIS Lookup, domain registrar, dates &amp; status (via RDAP) | KB Cafe"
  description="Look up any domain's registration, free and in your browser. Registrar, creation and expiry dates, status codes, nameservers, and DNSSEC, fetched live over RDAP (the modern WHOIS). Honest about redacted data and unsupported TLDs."
  path="/whois-lookup"
  eyebrow="Knowledge Base · Networking · Tool"
  h1="WHOIS Lookup"
  tagline="Enter a domain to see its registration: registrar, key dates, status, and nameservers. Fetched live over RDAP (the modern WHOIS) in your browser, nothing is sent to KB Cafe."
>
  <div class="wl"> <form class="wl-form" id="wl-form"> <div class="wl-inputs"> <input class="wl-domain" id="wl-domain" type="text" placeholder="example.com" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="Domain to look up"> <button class="btn wl-go" id="wl-go" type="submit">Look up</button> </div> <div class="wl-samples"> <span class="wl-samples-lbl">Try one:</span> <button class="chip" type="button" data-d="google.com">google.com</button> <button class="chip" type="button" data-d="github.com">github.com</button> <button class="chip" type="button" data-d="wikipedia.org">wikipedia.org</button> <button class="chip" type="button" data-d="openai.com">openai.com</button> </div> </form> <div class="wl-results" id="wl-results" hidden></div> </div>

  <Fragment slot="explainer">
  <div class="prose"> <h2>What this tool shows</h2> <p>
It fetches a domain&rsquo;s registration record <strong>live, in your browser</strong>, over
<strong>RDAP</strong>, the structured JSON successor to WHOIS, and lays out the parts that are public:
</p> <ul> <li><strong>Registrar</strong> and key <strong>dates</strong> (registered, expires, updated).</li> <li><strong>Status codes</strong> (like <code>clientTransferProhibited</code>, the healthy registrar lock).</li> <li><strong>Nameservers</strong> and whether <strong>DNSSEC</strong> is enabled.</li> </ul> <p>
Two honest limits: registrant <strong>personal contact data is redacted</strong> for privacy (GDPR), and a few
      TLDs don&rsquo;t expose browser-accessible RDAP, those return a clear notice rather than a wrong answer. New to
      this? Read <a href="/what-is-whois">what WHOIS is</a>. To see where the domain points, use the
<a href="/dns-lookup">DNS lookup</a>.
</p> </div>
  </Fragment>

  <script is:inline>
  (function () {
    var form = document.getElementById('wl-form');
    if (!form) return;
    var domEl = document.getElementById('wl-domain');
    var out = document.getElementById('wl-results');

    var STATUS_NOTE = {
      clienttransferprohibited: 'registrar lock (good)', servertransferprohibited: 'registry lock (good)',
      clientupdateprohibited: 'update lock', clientdeleteprohibited: 'delete lock',
      clienthold: 'suspended, not in DNS', serverhold: 'suspended by registry',
      pendingdelete: 'about to drop', redemptionperiod: 'expired, recoverable',
      autorenewperiod: 'recently renewed', addperiod: 'newly registered', ok: 'no restrictions', active: 'no restrictions',
    };

    function clean(d) {
      return (d || '').trim().toLowerCase()
        .replace(/^https?:\/\//, '').replace(/\/.*$/, '')
        .replace(/^www\./, '').replace(/[^a-z0-9.-]/g, '');
    }
    function esc(s) { return String(s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }

    function vcardFn(e) {
      var v = e.vcardArray && e.vcardArray[1];
      if (!v) return e.handle || null;
      var fn = v.find(function (p) { return p[0] === 'fn'; });
      return fn ? fn[3] : (e.handle || null);
    }
    function registrar(d) {
      var e = (d.entities || []).find(function (x) { return (x.roles || []).indexOf('registrar') >= 0; });
      return e ? vcardFn(e) : null;
    }
    function evt(d, a) {
      var e = (d.events || []).find(function (x) { return x.eventAction === a; });
      return e ? e.eventDate.slice(0, 10) : null;
    }

    function row(label, val) {
      if (!val) return '';
      return '<div class="wl-row"><span class="wl-k">' + label + '</span><span class="wl-v">' + val + '</span></div>';
    }

    function render(domain, d) {
      var reg = registrar(d);
      var created = evt(d, 'registration');
      var expires = evt(d, 'expiration');
      var updated = evt(d, 'last changed');
      var ns = (d.nameservers || []).map(function (n) { return (n.ldhName || '').toLowerCase(); }).filter(Boolean);
      var dnssec = d.secureDNS && d.secureDNS.delegationSigned;
      var status = (d.status || []);

      var expHtml = expires;
      if (expires) {
        var days = Math.round((new Date(expires + 'T00:00:00Z') - new Date()) / 86400000);
        if (!isNaN(days)) {
          if (days < 0) expHtml = expires + ' <span class="wl-flag bad">expired</span>';
          else if (days < 30) expHtml = expires + ' <span class="wl-flag warn">in ' + days + ' days</span>';
          else expHtml = expires + ' <span class="wl-flag ok">in ' + days + ' days</span>';
        }
      }
      var statusHtml = status.length
        ? '<div class="wl-status">' + status.map(function (s) {
            var note = STATUS_NOTE[String(s).toLowerCase().replace(/\s+/g, '')];
            return '<span class="wl-chip" title="' + esc(note || s) + '">' + esc(s) + (note ? '<em> · ' + esc(note) + '</em>' : '') + '</span>';
          }).join('') + '</div>'
        : '';
      var nsHtml = ns.length ? '<div class="wl-ns">' + ns.map(function (n) { return '<code>' + esc(n) + '</code>'; }).join('') + '</div>' : '';

      out.innerHTML =
        '<div class="wl-card">' +
          '<div class="wl-for">' + esc((d.ldhName || domain).toLowerCase()) + '</div>' +
          row('Registrar', reg ? esc(reg) : null) +
          row('Registered', created) +
          row('Expires', expHtml) +
          row('Updated', updated) +
          (statusHtml ? '<div class="wl-row wl-row-block"><span class="wl-k">Status</span>' + statusHtml + '</div>' : '') +
          (nsHtml ? '<div class="wl-row wl-row-block"><span class="wl-k">Nameservers</span>' + nsHtml + '</div>' : '') +
          row('DNSSEC', dnssec === true ? 'Signed' : dnssec === false ? 'Not signed' : null) +
        '</div>' +
        '<p class="wl-note">Registrant, admin, and tech contacts are redacted for privacy (GDPR). The registrar can relay contact via its own form. Source: RDAP, queried live from your browser.</p>';
      out.hidden = false;
    }

    async function go(domain) {
      out.hidden = false;
      out.innerHTML = '<div class="wl-loading">Looking up <strong>' + esc(domain) + '</strong>…</div>';
      try {
        var r = await fetch('https://rdap.org/domain/' + encodeURIComponent(domain), { headers: { accept: 'application/rdap+json' } });
        if (r.status === 404) { out.innerHTML = '<div class="wl-empty">No registration found for <strong>' + esc(domain) + '</strong>. It may be available, or this TLD&rsquo;s registry doesn&rsquo;t publish RDAP.</div>'; return; }
        if (!r.ok) throw new Error('rdap ' + r.status);
        render(domain, await r.json());
      } catch (e) {
        out.innerHTML = '<div class="wl-err">Couldn&rsquo;t fetch registration for <strong>' + esc(domain) + '</strong>. Some TLDs don&rsquo;t allow browser (RDAP) lookups, try the registry&rsquo;s own WHOIS page for those.</div>';
      }
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var d = clean(domEl.value);
      if (!d || d.indexOf('.') < 0) { domEl.focus(); return; }
      go(d);
    });
    Array.prototype.forEach.call(document.querySelectorAll('.wl-samples .chip'), function (b) {
      b.addEventListener('click', function () { domEl.value = b.getAttribute('data-d'); go(b.getAttribute('data-d')); });
    });
  })();
  </script>
</ToolPage>

<!-- styles restored 2026-06-21 (lost in the 06-20 dist recovery). is:global because the results are innerHTML-built. -->
<style is:global>
  .wl{max-width:680px}
  .wl-form{margin:0}
  .wl-inputs{display:flex;gap:10px;align-items:stretch;margin-bottom:14px}
  .wl-domain{flex:1;min-width:0;height:52px;border:1.5px solid var(--line);border-radius:14px;background:var(--cream);padding:0 18px;font-family:var(--font-body);font-size:16px;color:var(--ink);outline:0;transition:border-color .15s,box-shadow .15s}
  .wl-domain:focus{border-color:var(--ink);box-shadow:0 0 0 3px rgba(238,75,43,.1)}
  .wl-domain::placeholder{color:#a99e90}
  .wl-go.btn{flex:0 0 auto;height:52px;display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:0 26px;font-size:15px}
  .wl-samples{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .wl-samples-lbl{font-family:var(--font-mono);font-size:12.5px;color:var(--ink-soft)}

  .wl-results{margin-top:24px}
  .wl-card{border:1.5px solid var(--line);border-radius:16px;background:var(--cream);overflow:hidden}
  .wl-for{font-family:var(--font-mono);font-weight:700;font-size:15px;color:var(--ink);padding:14px 18px;border-bottom:1px solid var(--line);background:var(--paper-2)}
  .wl-card .wl-row{display:flex;gap:16px;align-items:baseline;padding:12px 18px;border-bottom:1px solid var(--line)}
  .wl-card .wl-row:last-child{border-bottom:0}
  .wl-row-block{flex-direction:column;gap:9px;align-items:stretch}
  .wl-k{font-family:var(--font-mono);font-size:11.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);flex:0 0 130px}
  .wl-v{font-size:14.5px;color:var(--ink);min-width:0;word-break:break-word}
  .wl-flag{display:inline-flex;align-items:center;margin-left:8px;padding:2px 9px;border-radius:999px;font-family:var(--font-mono);font-size:11px;font-weight:700}
  .wl-flag.ok{background:#dcf3ee;color:#0c7a5f}
  .wl-flag.warn{background:#fff0d6;color:#a86a12}
  .wl-flag.bad{background:#ffe0da;color:var(--coral-deep)}
  .wl-status{display:flex;flex-wrap:wrap;gap:7px}
  .wl-chip{display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border-radius:999px;background:var(--paper-2);border:1px solid var(--line);font-family:var(--font-mono);font-size:12px;color:var(--ink)}
  .wl-chip em{font-style:normal;color:var(--ink-soft);font-size:11.5px}
  .wl-ns{display:flex;flex-wrap:wrap;gap:8px}
  .wl-ns code{font-family:var(--font-mono);font-size:12.5px;background:var(--paper-2);border:1px solid var(--line);border-radius:8px;padding:5px 10px;color:var(--ink)}
  .wl-note{margin:14px 2px 0;font-size:12.5px;line-height:1.5;color:var(--ink-soft)}
  .wl-loading,.wl-empty,.wl-err{padding:16px 18px;border:1.5px solid var(--line);border-radius:14px;background:var(--cream);font-size:14.5px;color:var(--ink-soft)}
  .wl-err{border-color:rgba(238,75,43,.3)}
  @media(max-width:520px){.wl-inputs{flex-wrap:wrap}.wl-domain{flex:1 1 100%}.wl-go.btn{flex:1 1 100%}.wl-card .wl-row{flex-direction:column;gap:5px}.wl-k{flex-basis:auto}}
</style>
