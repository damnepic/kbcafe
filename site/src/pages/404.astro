---
import Layout from '../layouts/Layout.astro';
// Full-width, no sidebar/breadcrumb. Built to recover backlink referrals:
// the old kbcafe.com earned links over 25 years, so a dead-end here wastes equity.
// Give visitors (and crawlers) clear, crawlable paths back into the live content.
const SECTIONS = [
  { href: '/tools', label: 'Tools', ds: 'Developer & AI tools, all client-side' },
  { href: '/ai', label: 'AI Explained', ds: 'How modern AI actually works' },
  { href: '/reference', label: 'Reference', ds: 'Quick, no-fluff technical references' },
  { href: '/learn', label: 'Learn', ds: 'Guided, hands-on AI paths' },
  { href: '/feeds', label: 'Feeds & RSS', ds: 'The open-web syndication layer' },
  { href: '/blog', label: 'Blog', ds: 'Notes on the open web and AI' },
];
---
<Layout
  title="Page not found (404) | KB Cafe"
  description="That page has moved or never existed. Search KB Cafe or jump to tools, AI explainers, references, and learning paths."
  path="/404"
  sidebar={false}
  bodyClass="nf"
>
  <section class="nf-wrap">
    <div class="nf-badge">404</div>
    <h1>This page isn't brewed.</h1>
    <p class="nf-lede">
      The link you followed is broken, or the page moved. KB Cafe has been around since 1999, so a
      few old URLs drift, but the good stuff is all still here. Try a search, or pick a section below.
    </p>

    <form class="nf-search" action="/search" method="get" role="search">
      <span class="nf-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></span>
      <input type="search" name="q" id="nf-q" placeholder="Search tools, references & AI topics…" aria-label="Search KB Cafe" autocomplete="off" />
      <button type="submit">Search</button>
    </form>
    <p class="nf-tried" id="nf-tried" hidden></p>

    <div class="nf-grid">
      {SECTIONS.map(s => (
        <a class="nf-card" href={s.href}>
          <span class="nf-nm">{s.label}</span>
          <span class="nf-ds">{s.ds}</span>
          <span class="nf-go">open →</span>
        </a>
      ))}
    </div>

    <p class="nf-foot">Or head back to the <a href="/">KB Cafe home page</a>.</p>
  </section>
</Layout>

<style>
  .nf-wrap{max-width:760px;margin:30px auto 0;text-align:center}
  .nf-badge{display:inline-block;font-family:var(--font-mono);font-weight:800;font-size:13px;letter-spacing:.18em;
    color:var(--coral-deep);background:rgba(238,75,43,.12);border-radius:999px;padding:6px 14px;margin-bottom:18px}
  .nf-wrap h1{font-family:var(--font-display);font-weight:800;font-size:clamp(34px,6vw,52px);letter-spacing:-.03em;line-height:1.05;margin:0}
  .nf-lede{color:var(--ink-soft);font-size:16px;line-height:1.6;max-width:600px;margin:16px auto 28px}
  .nf-search{display:grid;grid-template-columns:26px 1fr auto;align-items:center;gap:10px;max-width:560px;margin:0 auto 8px;
    background:var(--cream);border:1.5px solid var(--line);border-radius:14px;padding:12px 14px;
    box-shadow:0 10px 30px rgba(40,24,12,.06);transition:border-color .16s,box-shadow .16s}
  .nf-search:focus-within{border-color:var(--coral);box-shadow:0 14px 40px rgba(238,75,43,.13)}
  .nf-ic{display:grid;place-items:center;color:var(--ink-soft)}.nf-ic svg{width:18px;height:18px}
  .nf-search input{border:0;outline:0;background:transparent;font-family:var(--font-body);font-size:15px;color:var(--ink);min-width:0}
  .nf-search button{border:0;border-radius:9px;background:var(--coral);color:#fff;font-family:var(--font-display);font-weight:800;font-size:14px;padding:9px 18px;cursor:pointer}
  .nf-search button:hover{background:var(--coral-deep)}
  .nf-tried{font-family:var(--font-mono);font-size:12px;color:var(--ink-soft);margin:0 0 30px}
  .nf-tried b{color:var(--ink)}
  .nf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;text-align:left;margin-top:14px}
  .nf-card{display:flex;flex-direction:column;gap:4px;padding:16px 18px;border-radius:15px;background:rgba(255,255,255,.6);
    border:1.2px solid var(--line);text-decoration:none;color:var(--ink);transition:transform .16s,box-shadow .16s,border-color .16s}
  .nf-card:hover{transform:translateY(-3px);box-shadow:0 16px 38px rgba(40,24,12,.09);border-color:rgba(238,75,43,.35)}
  .nf-nm{font-family:var(--font-display);font-weight:800;font-size:16px}
  .nf-ds{color:var(--ink-soft);font-size:13px;line-height:1.4}
  .nf-go{margin-top:4px;color:var(--coral);font-family:var(--font-display);font-weight:800;font-size:12.5px}
  .nf-foot{margin-top:30px;color:var(--ink-soft);font-size:14px}
  .nf-foot a{color:var(--coral);font-weight:700;text-decoration:none}
  .nf-foot a:hover{text-decoration:underline}
  @media(max-width:640px){.nf-grid{grid-template-columns:1fr}}
</style>

<script is:inline>
  // Surface the path the visitor tried, and pre-fill search with a guess from the slug.
  (function () {
    try {
      var path = decodeURIComponent(location.pathname || '');
      if (path && path !== '/' && path !== '/404') {
        var tried = document.getElementById('nf-tried');
        if (tried) { tried.innerHTML = 'You tried <b>' + path.replace(/[<>&]/g, '') + '</b>, it’s not here.'; tried.hidden = false; }
        var guess = path.split('/').filter(Boolean).pop() || '';
        guess = guess.replace(/\.(html?|aspx?|php|xml|cgi)$/i, '').replace(/[-_+]/g, ' ').trim();
        var q = document.getElementById('nf-q');
        if (q && guess && guess.length <= 40) q.value = guess;
      }
    } catch (e) {}
  })();
</script>
