---
import ToolPage from '../layouts/ToolPage.astro';
// A harmless sample token (HS256, signature is not valid — for demo only).
const sample = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkFkYSBMb3ZlbGFjZSIsImFkbWluIjp0cnVlLCJpYXQiOjE3MTYyMzkwMjIsImV4cCI6MTcxNjI0MjYyMn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c';
---
<ToolPage
  title="JWT Decoder — decode &amp; inspect JSON Web Tokens | KB Cafe"
  description="Paste a JWT to decode its header and payload, read the claims, and see when it expires. Free, fast, fully client-side — your token never leaves your browser."
  path="/jwt-decoder"
  eyebrow="Encoding · Auth"
  h1="JWT Decoder"
  tagline="Decode a JSON Web Token to read its header, payload, and claims. Everything is decoded locally in your browser — your token is never sent anywhere."
>
  <div class="pane" style="margin-bottom:18px">
    <div class="pane-label"><span>Token</span><button class="link-btn" id="sample">load sample</button></div>
    <textarea id="token" class="ta" style="min-height:120px" spellcheck="false" placeholder="Paste a JWT (eyJ…) here…"></textarea>
  </div>
  <p class="status" id="status"></p>

  <div class="panes">
    <div class="pane">
      <div class="pane-label"><span style="color:var(--coral)">■ Header</span></div>
      <pre class="ta out-pre" id="header"></pre>
    </div>
    <div class="pane">
      <div class="pane-label"><span style="color:var(--gold)">■ Payload</span></div>
      <pre class="ta out-pre" id="payload"></pre>
    </div>
  </div>

  <div id="claims" class="claims"></div>

  <Fragment slot="explainer">
    <h2>What a JWT actually is</h2>
    <p>
      A <strong>JSON Web Token</strong> is three Base64URL-encoded parts joined by dots:
      <code>header.payload.signature</code>. The header says which algorithm signed it, the
      payload carries the claims (who the token is for, when it expires), and the signature lets
      a server verify the first two parts weren&rsquo;t tampered with. This tool decodes the
      header and payload so you can read them — decoding is <em>not</em> the same as verifying.
    </p>

    <h3>Common claims you&rsquo;ll see</h3>
    <ul>
      <li><code>iss</code> — issuer, who created the token.</li>
      <li><code>sub</code> — subject, usually the user ID.</li>
      <li><code>aud</code> — audience, who the token is meant for.</li>
      <li><code>exp</code> — expiry (Unix seconds); after this the token is invalid.</li>
      <li><code>iat</code> — issued-at; <code>nbf</code> — not-valid-before.</li>
    </ul>
    <p>This decoder humanizes <code>exp</code>, <code>iat</code>, and <code>nbf</code> into readable dates and flags an expired token.</p>

    <h2 style="color:var(--coral-deep)">Security note — read this</h2>
    <p>
      <strong>The payload is only encoded, not encrypted.</strong> Anyone holding the token can
      read every claim — exactly like this page does. Never put secrets in a JWT payload, and never
      trust a token without verifying its signature on the server. This tool deliberately does
      <em>not</em> ask for your signing secret: it decodes locally and never transmits your token.
    </p>

    <h2>FAQ</h2>
    <details class="faq"><summary>Does this verify the signature?</summary>
      <p>No. Verifying requires your secret or public key, which should stay on your server. This tool only decodes the readable header and payload — the safe, common need when debugging.</p>
    </details>
    <details class="faq"><summary>Is my token sent to a server?</summary>
      <p>Never. All decoding is JavaScript running on this page, so your token stays in your browser and the tool works offline.</p>
    </details>
    <details class="faq"><summary>Why does it say my token is expired?</summary>
      <p>The <code>exp</code> claim is in the past relative to your device clock. An expired token will be rejected by a correctly configured server.</p>
    </details>

    <h3>Related references</h3>
    <p>Working with the JSON inside a token? Generate types with <a href="/json-to-typescript">JSON → TypeScript</a>. Scheduling token refreshes? Build the timing with the <a href="/cron-generator">cron generator</a>.</p>
  </Fragment>
</ToolPage>

<style>
  .link-btn{font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
    color:var(--coral);background:none;border:0;cursor:pointer}
  .link-btn:hover{color:var(--coral-deep);text-decoration:underline}
  .out-pre{min-height:220px;overflow:auto;white-space:pre-wrap;word-break:break-word;margin:0}
  .claims{margin-top:18px;display:none}
  .claims.show{display:block}
  .claims table{width:100%;border-collapse:collapse;font-family:var(--font-mono);font-size:13px}
  .claims caption{text-align:left;font-family:var(--font-display);font-weight:800;font-size:18px;margin-bottom:10px}
  .claims td{padding:9px 12px;border:1px solid var(--line);vertical-align:top}
  .claims td:first-child{color:var(--coral);font-weight:700;white-space:nowrap;width:1%}
  .claims .exp-bad{color:var(--coral-deep);font-weight:700}
  .claims .exp-ok{color:#2f7d32;font-weight:700}
</style>

<script is:inline define:vars={{ sample }}>
  const $ = id => document.getElementById(id);
  const tok = $('token'), statusEl = $('status'),
        headerEl = $('header'), payloadEl = $('payload'), claimsEl = $('claims');

  function b64urlDecode(str){
    str = str.replace(/-/g, '+').replace(/_/g, '/');
    while(str.length % 4) str += '=';
    const bin = atob(str);
    // handle UTF-8
    const bytes = Uint8Array.from(bin, c => c.charCodeAt(0));
    return new TextDecoder('utf-8').decode(bytes);
  }
  function pretty(obj){ return JSON.stringify(obj, null, 2); }
  const TIME_CLAIMS = { exp: 'Expires', iat: 'Issued at', nbf: 'Not before', auth_time: 'Auth time' };

  function fmtTime(sec){
    const d = new Date(sec * 1000);
    if(isNaN(d)) return String(sec);
    return d.toUTCString() + '  ·  ' + d.toLocaleString();
  }

  function decode(){
    const raw = tok.value.trim();
    statusEl.className = 'status'; statusEl.textContent = '';
    tok.classList.remove('err');
    headerEl.textContent = ''; payloadEl.textContent = '';
    claimsEl.classList.remove('show'); claimsEl.innerHTML = '';
    if(!raw) return;

    const parts = raw.split('.');
    if(parts.length < 2 || parts.length > 3){
      tok.classList.add('err'); statusEl.className = 'status bad';
      statusEl.textContent = 'Not a JWT — expected 2 or 3 dot-separated parts.';
      return;
    }
    let header, payload;
    try { header = JSON.parse(b64urlDecode(parts[0])); }
    catch { tok.classList.add('err'); statusEl.className='status bad'; statusEl.textContent='Could not decode the header segment.'; return; }
    try { payload = JSON.parse(b64urlDecode(parts[1])); }
    catch { tok.classList.add('err'); statusEl.className='status bad'; statusEl.textContent='Could not decode the payload segment.'; return; }

    headerEl.textContent = pretty(header);
    payloadEl.textContent = pretty(payload);

    // claims table
    const now = Math.floor(Date.now() / 1000);
    let expired = null;
    const rows = [];
    for(const [k, label] of Object.entries(TIME_CLAIMS)){
      if(typeof payload[k] === 'number'){
        let extra = '';
        if(k === 'exp'){ expired = payload[k] < now; extra = expired ? ' <span class="exp-bad">(expired)</span>' : ' <span class="exp-ok">(valid)</span>'; }
        if(k === 'nbf' && payload[k] > now){ extra = ' <span class="exp-bad">(not yet valid)</span>'; }
        rows.push(`<tr><td>${k}</td><td>${fmtTime(payload[k])}${extra}<br><span style="opacity:.55">${label}</span></td></tr>`);
      }
    }
    ['iss','sub','aud'].forEach(k => {
      if(payload[k] != null) rows.push(`<tr><td>${k}</td><td>${escapeHtml(String(Array.isArray(payload[k]) ? payload[k].join(', ') : payload[k]))}</td></tr>`);
    });
    if(rows.length){
      claimsEl.innerHTML = `<table><caption>Decoded claims</caption><tbody>${rows.join('')}</tbody></table>`;
      claimsEl.classList.add('show');
    }

    statusEl.className = 'status ok';
    statusEl.textContent = parts.length === 2
      ? `Decoded · alg ${header.alg || '?'} · unsecured (no signature segment).`
      : (expired === true ? `Decoded · alg ${header.alg || '?'} · token is EXPIRED.`
        : `Decoded · alg ${header.alg || '?'}${expired === false ? ' · not expired.' : '.'}`);
    if(expired) statusEl.className = 'status bad';
  }
  function escapeHtml(s){ return s.replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c])); }

  tok.addEventListener('input', decode);
  $('sample').addEventListener('click', () => { tok.value = sample; decode(); });
  tok.value = sample; decode();
</script>
