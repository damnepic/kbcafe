---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact KB Cafe"
  description="Questions, feedback, or a broken link? Send us a message and we will get back to you."
  path="/contact"
  sidebar={false}
>
  <section class="ct">
    <h1>Get in touch</h1>
    <p class="ct-lede">Questions, feedback, a broken link, or just hello. Send it over and we will reply to the email you provide.</p>
    <form class="ct-form" id="ctForm" novalidate>
      <div class="ct-grid">
        <label class="ct-field"><span>Your name</span><input name="name" type="text" autocomplete="name" placeholder="Jane Doe" /></label>
        <label class="ct-field"><span>Your email <em>*</em></span><input name="email" type="email" autocomplete="email" placeholder="you@example.com" required /></label>
      </div>
      <label class="ct-field"><span>Message <em>*</em></span><textarea name="message" rows="6" placeholder="What is on your mind?" required></textarea></label>
      <input type="text" name="company" class="ct-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="ct-actions">
        <button type="submit" id="ctBtn">Send message</button>
        <span class="ct-status" id="ctStatus" hidden></span>
      </div>
    </form>
  </section>

  <script is:inline>
    (function () {
      var f = document.getElementById('ctForm'), btn = document.getElementById('ctBtn'), st = document.getElementById('ctStatus');
      if (!f) return;
      function show(cls, msg) { st.hidden = false; st.className = 'ct-status' + (cls ? ' ' + cls : ''); st.textContent = msg; }
      f.addEventListener('submit', async function (e) {
        e.preventDefault();
        var d = Object.fromEntries(new FormData(f).entries());
        if (!d.email || !d.message) { show('err', 'Please add your email and a message.'); return; }
        btn.disabled = true; show('', 'Sending...');
        try {
          var r = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(d) });
          var j = await r.json().catch(function () { return {}; });
          if (r.ok && j.ok) { f.reset(); show('ok', 'Thanks! Your message is on its way. We will reply to your email.'); }
          else { show('err', (j && j.error) || 'Something went wrong. Please try again in a moment.'); }
        } catch (err) { show('err', 'Could not send right now. Please try again in a moment.'); }
        btn.disabled = false;
      });
    })();
  </script>
</Layout>

<style>
  .ct{max-width:640px;margin:0 auto;padding:34px 0 50px}
  .ct h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;font-size:clamp(30px,4.5vw,46px)}
  .ct-lede{font-size:16.5px;color:var(--ink-soft);margin-top:12px;line-height:1.55}
  .ct-form{margin-top:26px;display:flex;flex-direction:column;gap:16px}
  .ct-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .ct-field{display:flex;flex-direction:column;gap:7px}
  .ct-field span{font-family:var(--font-mono);font-size:11.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft)}
  .ct-field em{color:var(--coral);font-style:normal}
  .ct-field input,.ct-field textarea{font-family:var(--font-body);font-size:15px;color:var(--ink);background:var(--cream);border:1.4px solid var(--line);border-radius:11px;padding:12px 14px;outline:0;transition:border-color .14s}
  .ct-field input:focus,.ct-field textarea:focus{border-color:var(--ink)}
  .ct-field textarea{resize:vertical;min-height:130px}
  .ct-hp{position:absolute;left:-9999px;width:1px;height:1px;opacity:0}
  .ct-actions{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-top:4px}
  .ct-actions button{height:50px;border:0;border-radius:13px;padding:0 26px;background:linear-gradient(135deg,#ff5839,#e23a1d);color:#fff;font-family:var(--font-display);font-weight:800;font-size:15.5px;cursor:pointer;transition:transform .15s,box-shadow .15s}
  .ct-actions button:hover{transform:translateY(-2px);box-shadow:0 12px 26px rgba(226,58,29,.26)}
  .ct-actions button:disabled{opacity:.6;cursor:not-allowed;transform:none;box-shadow:none}
  .ct-status{font-family:var(--font-mono);font-size:13px;font-weight:600}
  .ct-status.ok{color:#2f7d32}.ct-status.err{color:var(--coral-deep)}
  @media(max-width:560px){.ct-grid{grid-template-columns:1fr}}
</style>
