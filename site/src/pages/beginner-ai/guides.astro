---
import Layout from '../../layouts/Layout.astro';
import { BG_TOPICS, BG_LEVELS, BG_GUIDES, bgTopicLabel } from '../../data/beginnerGuides.js';
---
<Layout
  title="Every AI guide for beginners, organized | KB Cafe"
  description="Filter beginner AI guides by topic or difficulty. Each article is written in plain language, with practical examples you can try immediately."
  path="/beginner-ai/guides"
  sidebar={false}
  noindex={true}
>
  <div class="bg">
    <a class="bg-back" href="/beginner-ai">&larr; Beginner AI</a>
    <h1>Every guide, organized and ready.</h1>
    <p class="bg-lede">Filter by topic or difficulty. Each article is written in plain language, with practical examples you can try immediately.</p>

    <div class="bg-filter">
      <div class="bg-fl">Filter by topic</div>
      <div class="bg-pills" id="topics">
        <button class="bg-pill on" data-topic="all">All topics</button>
        {BG_TOPICS.map((t) => <button class="bg-pill" data-topic={t.id}>{t.label}</button>)}
      </div>
    </div>
    <div class="bg-filter">
      <div class="bg-fl">Difficulty</div>
      <div class="bg-pills" id="levels">
        <button class="bg-pill on" data-level="all">All levels</button>
        {BG_LEVELS.map((l) => <button class="bg-pill" data-level={l}>{l}</button>)}
      </div>
    </div>

    <p class="bg-count" id="count">Showing {BG_GUIDES.length} articles</p>

    <div class="bg-grid" id="grid">
      {BG_GUIDES.map((g) => (
        <a class="bg-card" href={`/beginner-ai/${g.slug}`} data-topic={g.topic} data-level={g.level}>
          <div class="bg-tags"><span class="bg-tag bg-tag-topic">{bgTopicLabel(g.topic)}</span><span class="bg-tag bg-tag-lvl">{g.level}</span></div>
          <h3>{g.title}</h3>
          <p>{g.excerpt}</p>
          <span class="bg-min">&#128337; {g.minutes} min read</span>
        </a>
      ))}
    </div>
    <p class="bg-none" id="none" hidden>No guides match those filters yet. Try widening them, more are on the way.</p>
  </div>

  <script>
    var topic = 'all', level = 'all';
    var cards = Array.prototype.slice.call(document.querySelectorAll('.bg-card'));
    var countEl = document.getElementById('count'), none = document.getElementById('none');
    function apply() {
      var n = 0;
      cards.forEach(function (c) {
        var ok = (topic === 'all' || c.dataset.topic === topic) && (level === 'all' || c.dataset.level === level);
        c.hidden = !ok; if (ok) n++;
      });
      countEl.textContent = 'Showing ' + n + ' article' + (n === 1 ? '' : 's');
      none.hidden = n > 0;
    }
    function wire(groupId, setFn) {
      document.getElementById(groupId).addEventListener('click', function (e) {
        var b = e.target.closest('.bg-pill'); if (!b) return;
        this.querySelectorAll('.bg-pill').forEach(function (p) { p.classList.remove('on'); });
        b.classList.add('on'); setFn(b); apply();
      });
    }
    wire('topics', function (b) { topic = b.dataset.topic; });
    wire('levels', function (b) { level = b.dataset.level; });
    // read ?topic= from the hub
    var p = new URLSearchParams(location.search).get('topic');
    if (p) {
      var btn = document.querySelector('#topics .bg-pill[data-topic="' + p + '"]');
      if (btn) { document.querySelectorAll('#topics .bg-pill').forEach(function (x) { x.classList.remove('on'); }); btn.classList.add('on'); topic = p; }
    }
    apply();
  </script>
</Layout>

<style>
  .bg{max-width:1000px;margin:0 auto;padding:34px 0 50px;--bz-soft:#574b3f;--bz-mute:#8a7e6e;--bz-line:rgba(30,24,19,.12)}
  .bg-back{font-family:var(--font-mono);font-size:12.5px;font-weight:600;color:var(--bz-mute);text-decoration:none}
  .bg-back:hover{color:#3478f6}
  .bg h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.03em;font-size:clamp(30px,4.6vw,46px);margin:16px 0 0}
  .bg-lede{font-size:16.5px;color:var(--bz-soft);margin-top:12px;max-width:560px;line-height:1.55}
  .bg-filter{margin-top:22px}
  .bg-fl{display:flex;align-items:center;gap:7px;font-family:var(--font-mono);font-size:11.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--bz-mute);margin-bottom:10px}
  .bg-pills{display:flex;flex-wrap:wrap;gap:8px}
  .bg-pill{height:34px;border-radius:999px;border:1.3px solid var(--bz-line);background:#fff;color:var(--bz-soft);padding:0 15px;font-family:var(--font-body);font-size:13.5px;font-weight:600;cursor:pointer;transition:all .14s}
  .bg-pill:hover{border-color:#9fc0f7}
  .bg-pill.on{background:#3478f6;color:#fff;border-color:#3478f6}
  .bg-count{margin:24px 0 14px;font-family:var(--font-mono);font-size:13px;color:var(--bz-soft)}
  .bg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .bg-card{display:flex;flex-direction:column;gap:10px;background:#fff;border:1.4px solid var(--bz-line);border-radius:16px;padding:18px;text-decoration:none;color:#1E1813;transition:transform .15s,box-shadow .15s,border-color .15s}
  .bg-card[hidden]{display:none}
  .bg-card:hover{transform:translateY(-4px);box-shadow:0 16px 34px rgba(40,30,12,.09);border-color:#9fc0f7}
  .bg-tags{display:flex;gap:6px;flex-wrap:wrap}
  .bg-tag{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px}
  .bg-tag-topic{background:#eaf1ff;color:#2a63cf}
  .bg-tag-lvl{background:#dcf3ee;color:#0c7a5f}
  .bg-card h3{font-family:var(--font-display);font-weight:800;font-size:16px;line-height:1.22}
  .bg-card p{font-size:13px;color:var(--bz-soft);line-height:1.45;flex:1}
  .bg-min{font-family:var(--font-mono);font-size:11.5px;color:var(--bz-mute)}
  .bg-none{margin-top:20px;font-size:15px;color:var(--bz-soft)}
  @media(max-width:820px){.bg-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:540px){.bg-grid{grid-template-columns:1fr}}
</style>
