---
import ToolPage from '../layouts/ToolPage.astro';
// NOTE: source recovered from build output 2026-06-20; slots + script injected verbatim.
const STAGE = "  <div class=\"dl\"> <form class=\"dl-form\" id=\"dl-form\"> <div class=\"dl-inputs\"> <input class=\"dl-domain\" id=\"dl-domain\" type=\"text\" placeholder=\"example.com\" autocomplete=\"off\" autocapitalize=\"off\" spellcheck=\"false\" aria-label=\"Domain to look up\"> <select class=\"dl-type\" id=\"dl-type\" aria-label=\"Record type\"> <option value=\"ALL\">All records</option> <option value=\"A\">A (IPv4)</option> <option value=\"AAAA\">AAAA (IPv6)</option> <option value=\"CNAME\">CNAME</option> <option value=\"MX\">MX (mail)</option> <option value=\"TXT\">TXT</option> <option value=\"NS\">NS</option> <option value=\"SOA\">SOA</option> <option value=\"CAA\">CAA</option> </select> <button class=\"btn dl-go\" id=\"dl-go\" type=\"submit\">Look up</button> </div> <div class=\"dl-samples\"> <span class=\"dl-samples-lbl\">Try one:</span> <button class=\"chip\" type=\"button\" data-d=\"google.com\">google.com</button> <button class=\"chip\" type=\"button\" data-d=\"github.com\">github.com</button> <button class=\"chip\" type=\"button\" data-d=\"cloudflare.com\">cloudflare.com</button> <button class=\"chip\" type=\"button\" data-d=\"vercel.com\">vercel.com</button> </div> </form> <div class=\"dl-results\" id=\"dl-results\" hidden></div> </div>   ";
const EXPLAINER = " <div class=\"prose\"> <h2>What this tool does</h2> <p>\nIt resolves a domain&rsquo;s DNS records <strong>live, in your browser</strong>, over DNS-over-HTTPS, and\n      groups them by type so they&rsquo;re readable. Use it to confirm a record you just added, debug why a name\n      won&rsquo;t resolve, or inspect how any domain is configured:\n</p> <ul> <li><strong>A / AAAA</strong>, the IPv4 / IPv6 addresses a name points to.</li> <li><strong>CNAME</strong>, aliases to another name. <strong>NS</strong>, the authoritative nameservers.</li> <li><strong>MX</strong>, mail servers. <strong>TXT</strong>, where SPF, DKIM, DMARC, and verification records live.</li> <li><strong>SOA</strong>, zone metadata. <strong>CAA</strong>, which certificate authorities may issue certs.</li> </ul> <p>\nNew to any of this? Start with <a href=\"/what-is-dns\">what DNS is</a>. Checking email setup specifically? The\n<a href=\"/email-deliverability-checker\">deliverability checker</a> scores SPF/DKIM/DMARC and tells you what to\n      fix.\n</p> </div> ";
const TOOLJS = "\n  (function () {\n    var form = document.getElementById('dl-form');\n    if (!form) return;\n    var domEl = document.getElementById('dl-domain');\n    var typeEl = document.getElementById('dl-type');\n    var out = document.getElementById('dl-results');\n\n    var TNUM = { 1: 'A', 28: 'AAAA', 5: 'CNAME', 15: 'MX', 16: 'TXT', 2: 'NS', 6: 'SOA', 257: 'CAA' };\n    var ORDER = ['A', 'AAAA', 'CNAME', 'NS', 'MX', 'TXT', 'SOA', 'CAA'];\n    var ALL = ['A', 'AAAA', 'CNAME', 'MX', 'TXT', 'NS', 'SOA', 'CAA'];\n\n    function clean(d) {\n      return (d || '').trim().toLowerCase()\n        .replace(/^https?:\\/\\//, '').replace(/\\/.*$/, '')\n        .replace(/^www\\./, '').replace(/[^a-z0-9.-]/g, '');\n    }\n    function esc(s) { return String(s).replace(/[&<>\"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;' }[c]; }); }\n    function cleanData(s) { return (s || '').replace(/\" \"/g, '').replace(/^\"|\"$/g, ''); }\n\n    async function query(name, type) {\n      var url = 'https://cloudflare-dns.com/dns-query?name=' + encodeURIComponent(name) + '&type=' + type;\n      var r = await fetch(url, { headers: { accept: 'application/dns-json' } });\n      if (!r.ok) throw new Error('dns ' + r.status);\n      return await r.json();\n    }\n\n    async function run(domain, types) {\n      var queried = [], byType = {};\n      for (var i = 0; i < types.length; i++) {\n        queried.push(types[i] + '  ' + domain);\n        var j = await query(domain, types[i]);\n        (j.Answer || []).forEach(function (a) {\n          var label = TNUM[a.type] || ('TYPE' + a.type);\n          (byType[label] = byType[label] || []).push({ ttl: a.TTL, data: cleanData(a.data) });\n        });\n      }\n      return { domain: domain, byType: byType, queried: queried };\n    }\n\n    function render(r) {\n      var groups = ORDER.filter(function (t) { return r.byType[t] && r.byType[t].length; });\n      var body;\n      if (!groups.length) {\n        body = '<div class=\"dl-empty\">No records found for <strong>' + esc(r.domain) + '</strong> in the types queried. Double-check the domain, or the record may not exist.</div>';\n      } else {\n        body = groups.map(function (t) {\n          var rows = r.byType[t].map(function (rec) {\n            return '<div class=\"dl-rec\"><span class=\"dl-ttl\" title=\"TTL (seconds)\">' + rec.ttl + 's</span>' +\n              '<code class=\"dl-val\">' + esc(rec.data) + '</code></div>';\n          }).join('');\n          return '<div class=\"dl-group\"><div class=\"dl-type-h\">' + t + ' <span class=\"dl-count\">' + r.byType[t].length + '</span></div>' + rows + '</div>';\n        }).join('');\n      }\n      var checked = r.queried.map(function (q) { return '<li><code>' + esc(q) + '</code></li>'; }).join('');\n      out.innerHTML =\n        '<div class=\"dl-for\">Records for <strong>' + esc(r.domain) + '</strong></div>' +\n        body +\n        '<details class=\"dl-checked\"><summary>What we queried (' + r.queried.length + ' lookups)</summary>' +\n          '<ul>' + checked + '</ul>' +\n          '<p class=\"dl-checked-note\">Resolved from your browser via Cloudflare DNS-over-HTTPS. Nothing is sent to KB Cafe.</p>' +\n        '</details>';\n      out.hidden = false;\n    }\n\n    async function go(domain, type) {\n      out.hidden = false;\n      out.innerHTML = '<div class=\"dl-loading\">Looking up <strong>' + esc(domain) + '</strong>…</div>';\n      try {\n        var types = type === 'ALL' ? ALL : [type];\n        render(await run(domain, types));\n      } catch (e) {\n        out.innerHTML = '<div class=\"dl-err\">Couldn’t complete the lookup (network or DNS error). Check the domain and try again.</div>';\n      }\n    }\n\n    form.addEventListener('submit', function (e) {\n      e.preventDefault();\n      var d = clean(domEl.value);\n      if (!d || d.indexOf('.') < 0) { domEl.focus(); return; }\n      go(d, typeEl.value);\n    });\n    Array.prototype.forEach.call(document.querySelectorAll('.dl-samples .chip'), function (b) {\n      b.addEventListener('click', function () { domEl.value = b.getAttribute('data-d'); go(b.getAttribute('data-d'), typeEl.value); });\n    });\n  })();\n";
---
<ToolPage
  title={"DNS Lookup, see any domain's records (A, MX, TXT, NS…) | KB Cafe"}
  description={"Look up any domain's DNS records, free and in your browser. Live A, AAAA, CNAME, MX, TXT, NS, SOA, and CAA records via DNS-over-HTTPS, grouped and readable, with the exact queries shown. Nothing is sent to us."}
  path="/dns-lookup"
  eyebrow={"Knowledge Base · Networking · Tool"}
  h1={"DNS Lookup"}
  tagline={"Enter a domain to see its live DNS records, A, AAAA, CNAME, MX, TXT, NS, SOA, and CAA. Resolved in your browser via DNS-over-HTTPS; nothing is sent to KB Cafe."}
>
  <Fragment set:html={STAGE} />
  <Fragment slot="explainer" set:html={EXPLAINER} />
  <script is:inline set:html={TOOLJS} />
</ToolPage>
