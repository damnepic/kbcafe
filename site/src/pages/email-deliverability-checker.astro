---
import ToolPage from '../layouts/ToolPage.astro';
// NOTE: source recovered from build output 2026-06-20; slots + script injected verbatim.
const STAGE = "  <div class=\"dc\"> <form class=\"dc-form\" id=\"dc-form\"> <div class=\"dc-inputs\"> <input class=\"dc-domain\" id=\"dc-domain\" type=\"text\" placeholder=\"yourdomain.com\" autocomplete=\"off\" autocapitalize=\"off\" spellcheck=\"false\" aria-label=\"Domain to check\"> <input class=\"dc-sel\" id=\"dc-sel\" type=\"text\" placeholder=\"DKIM selector (optional)\" autocomplete=\"off\" autocapitalize=\"off\" spellcheck=\"false\" aria-label=\"DKIM selector, optional\"> <button class=\"btn dc-go\" id=\"dc-go\" type=\"submit\">Check</button> </div> <div class=\"dc-samples\"> <span class=\"dc-samples-lbl\">Try one:</span> <button class=\"chip\" type=\"button\" data-d=\"google.com\">google.com</button> <button class=\"chip\" type=\"button\" data-d=\"cloudflare.com\">cloudflare.com</button> <button class=\"chip\" type=\"button\" data-d=\"openai.com\">openai.com</button> <button class=\"chip\" type=\"button\" data-d=\"github.com\">github.com</button> </div> </form> <div class=\"dc-results\" id=\"dc-results\" hidden></div> </div>   ";
const EXPLAINER = " <div class=\"prose\"> <h2>What this tool checks</h2> <p>\nEmail authentication is the biggest controllable reason legitimate mail lands in spam. This checker runs\n<strong>live DNS lookups in your browser</strong> (via DNS-over-HTTPS) and reports what it finds:\n</p> <ul> <li><strong>SPF</strong>, the <code>TXT</code> record listing who may send for the domain. See <a href=\"/spf-explained\">SPF explained</a>.</li> <li><strong>DMARC</strong>, the policy at <code>_dmarc.domain</code>, including whether it is <code>none</code>, <code>quarantine</code>, or <code>reject</code>. See <a href=\"/dmarc-explained\">DMARC explained</a>.</li> <li><strong>DKIM</strong>, the signing key, which lives behind a <em>selector</em> chosen by your provider. Because selectors can&rsquo;t be discovered from DNS, we probe common ones and let you enter yours. We report DKIM as <strong>Unknown</strong>, never &ldquo;missing,&rdquo; when we can&rsquo;t confirm it. See <a href=\"/dkim-explained\">DKIM explained</a>.</li> </ul> <p>\nThe <strong>score is a transparent rubric</strong>, every point is shown and traceable to a real DNS fact, no\n      black-box number. For the full picture of why mail goes to spam, start with the\n<a href=\"/email-deliverability\">deliverability guide</a>.\n</p> </div> ";
const TOOLJS = "\n  (function () {\n    var form = document.getElementById('dc-form');\n    if (!form) return;\n    var domEl = document.getElementById('dc-domain');\n    var selEl = document.getElementById('dc-sel');\n    var out = document.getElementById('dc-results');\n\n    // common DKIM selectors, ordered by rough prevalence\n    var SELECTORS = ['google', 'selector1', 'selector2', 'k1', 's1', 's2', 'default', 'dkim', 'mail', 'mandrill', 'mxvault', 'smtpapi'];\n\n    function clean(d) {\n      return (d || '').trim().toLowerCase()\n        .replace(/^https?:\\/\\//, '').replace(/\\/.*$/, '')\n        .replace(/^www\\./, '').replace(/[^a-z0-9.-]/g, '');\n    }\n    function esc(s) { return String(s).replace(/[&<>\"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;' }[c]; }); }\n\n    async function txt(name) {\n      var url = 'https://cloudflare-dns.com/dns-query?name=' + encodeURIComponent(name) + '&type=TXT';\n      var r = await fetch(url, { headers: { accept: 'application/dns-json' } });\n      if (!r.ok) throw new Error('dns ' + r.status);\n      var j = await r.json();\n      return (j.Answer || []).map(function (a) {\n        return (a.data || '').replace(/\" \"/g, '').replace(/^\"|\"$/g, '');\n      });\n    }\n\n    async function run(domain, userSel) {\n      var queried = [];\n      // SPF\n      queried.push('TXT ' + domain);\n      var spfRecs = await txt(domain);\n      var spf = spfRecs.find(function (t) { return /^v=spf1/i.test(t); }) || null;\n      var spfAll = spf ? (spf.match(/[~\\-?+]all\\b/) || [''])[0] : '';\n\n      // DMARC\n      queried.push('TXT _dmarc.' + domain);\n      var dmRecs = await txt('_dmarc.' + domain);\n      var dmarc = dmRecs.find(function (t) { return /v=DMARC1/i.test(t); }) || null;\n      var policy = dmarc ? ((dmarc.match(/\\bp=\\s*(none|quarantine|reject)/i) || [])[1] || 'none').toLowerCase() : null;\n\n      // DKIM (selector-based)\n      var sels = userSel ? [userSel] : SELECTORS;\n      var dkimSel = null, dkimRec = null;\n      for (var i = 0; i < sels.length; i++) {\n        var name = sels[i] + '._domainkey.' + domain;\n        queried.push('TXT ' + name);\n        var recs = await txt(name);\n        var hit = recs.find(function (t) { return /v=DKIM1/i.test(t) || /(^|;)\\s*p=/.test(t); });\n        if (hit) { dkimSel = sels[i]; dkimRec = hit; break; }\n      }\n\n      return { domain: domain, spf: spf, spfAll: spfAll, dmarc: dmarc, policy: policy, dkimSel: dkimSel, dkimRec: dkimRec, userSel: userSel || null, queried: queried };\n    }\n\n    function score(r) {\n      var pts = [];\n      pts.push({ ok: !!r.spf, label: r.spf ? 'SPF record found' : 'No SPF record', val: r.spf ? 30 : 0, state: r.spf ? 'ok' : 'bad' });\n      if (r.dkimSel) pts.push({ ok: true, label: 'DKIM found (selector: ' + r.dkimSel + ')', val: 20, state: 'ok' });\n      else pts.push({ ok: false, label: r.userSel ? 'DKIM not found for selector \"' + r.userSel + '\"' : 'DKIM status unknown (no common selector matched)', val: 0, state: 'unknown' });\n      pts.push({ ok: !!r.dmarc, label: r.dmarc ? 'DMARC record found' : 'No DMARC record', val: r.dmarc ? 20 : 0, state: r.dmarc ? 'ok' : 'bad' });\n      if (r.dmarc) {\n        var pv = r.policy === 'reject' ? 30 : r.policy === 'quarantine' ? 15 : 0;\n        var ps = r.policy === 'reject' ? 'ok' : r.policy === 'quarantine' ? 'ok' : 'warn';\n        pts.push({ ok: r.policy !== 'none', label: 'DMARC policy: p=' + r.policy + (r.policy === 'none' ? ' (monitor only)' : ''), val: pv, state: ps });\n      }\n      var total = pts.reduce(function (a, p) { return a + p.val; }, 0);\n      return { pts: pts, total: Math.min(100, total) };\n    }\n\n    function recommend(r) {\n      if (!r.spf) return { t: 'Add an SPF record', why: 'Receivers can’t tell which servers may send for you.', href: '/spf-explained' };\n      if (!r.dmarc) return { t: 'Publish a DMARC record (start at p=none)', why: 'Nothing ties SPF/DKIM together or reports who spoofs you.', href: '/dmarc-explained' };\n      if (r.policy === 'none') return { t: 'Move DMARC from p=none to p=quarantine', why: 'p=none monitors but enforces nothing. Tighten once your senders pass.', href: '/dmarc-explained' };\n      if (r.policy === 'quarantine') return { t: 'Tighten DMARC from quarantine to reject', why: 'reject is the only policy that fully stops spoofing.', href: '/dmarc-explained' };\n      if (!r.dkimSel) return { t: 'Confirm DKIM by entering your selector', why: 'We couldn’t auto-detect DKIM. Enter the selector your provider uses to verify it.', href: '/dkim-explained' };\n      return { t: 'Your email authentication looks strong', why: 'SPF, DKIM, and DMARC at reject are all in place. Keep an eye on reputation.', href: '/email-deliverability' };\n    }\n\n    function render(r) {\n      var s = score(r);\n      var grade = s.total >= 80 ? 'ok' : s.total >= 50 ? 'warn' : 'bad';\n      var rec = recommend(r);\n      var rows = s.pts.map(function (p) {\n        var sym = p.state === 'ok' ? '✓' : p.state === 'warn' ? '⚠' : p.state === 'unknown' ? '?' : '✗';\n        return '<div class=\"dc-row dc-' + p.state + '\"><span class=\"dc-sym\">' + sym + '</span>' +\n          '<span class=\"dc-row-l\">' + esc(p.label) + '</span>' +\n          '<span class=\"dc-row-pts\">+' + p.val + '</span></div>';\n      }).join('');\n      var checkedList = r.queried.map(function (q) { return '<li><code>' + esc(q) + '</code></li>'; }).join('');\n      var dkimHint = (!r.dkimSel && !r.userSel)\n        ? '<p class=\"dc-hint\">DKIM is reported as <strong>Unknown</strong>, not missing: it lives behind a selector we couldn’t guess. If you know yours (often <code>google</code>, <code>selector1</code>, <code>k1</code>…), enter it above and check again.</p>'\n        : '';\n\n      out.innerHTML =\n        '<div class=\"dc-scorecard dc-grade-' + grade + '\">' +\n          '<div class=\"dc-score\"><span class=\"dc-score-n\">' + s.total + '</span><span class=\"dc-score-d\">/ 100</span></div>' +\n          '<div class=\"dc-score-for\">Authentication score for <strong>' + esc(r.domain) + '</strong>' +\n            '<span class=\"dc-score-note\">verified DNS facts only · every point is shown below</span></div>' +\n        '</div>' +\n        '<div class=\"dc-rows\">' + rows + '</div>' +\n        dkimHint +\n        '<div class=\"dc-rec\"><span class=\"dc-rec-lbl\">Biggest improvement</span>' +\n          '<a class=\"dc-rec-t\" href=\"' + rec.href + '\">' + esc(rec.t) + ' &rarr;</a>' +\n          '<span class=\"dc-rec-why\">' + esc(rec.why) + '</span></div>' +\n        '<details class=\"dc-checked\"><summary>What we checked (' + r.queried.length + ' DNS lookups)</summary>' +\n          '<ul>' + checkedList + '</ul>' +\n          '<p class=\"dc-checked-note\">Lookups run from your browser via Cloudflare DNS-over-HTTPS. Nothing is sent to KB Cafe.</p>' +\n        '</details>';\n      out.hidden = false;\n    }\n\n    async function go(domain, sel) {\n      out.hidden = false;\n      out.innerHTML = '<div class=\"dc-loading\">Looking up DNS for <strong>' + esc(domain) + '</strong>…</div>';\n      try {\n        var r = await run(domain, sel);\n        render(r);\n      } catch (e) {\n        out.innerHTML = '<div class=\"dc-err\">Couldn’t complete the lookup (network or DNS error). Check the domain and try again.</div>';\n      }\n    }\n\n    form.addEventListener('submit', function (e) {\n      e.preventDefault();\n      var d = clean(domEl.value);\n      var sel = (selEl.value || '').trim().toLowerCase().replace(/[^a-z0-9._-]/g, '');\n      if (!d || d.indexOf('.') < 0) { domEl.focus(); return; }\n      go(d, sel);\n    });\n    Array.prototype.forEach.call(document.querySelectorAll('.dc-samples .chip'), function (b) {\n      b.addEventListener('click', function () { domEl.value = b.getAttribute('data-d'); selEl.value = ''; go(b.getAttribute('data-d'), ''); });\n    });\n  })();\n";
---
<ToolPage
  title={"Email Deliverability Checker, SPF / DKIM / DMARC | KB Cafe"}
  description={"Check any domain's email authentication, free and in your browser. Live DNS lookups for SPF, DMARC (and DKIM by selector), a transparent deliverability score, the single biggest improvement to make, and exactly which DNS records we queried."}
  path="/email-deliverability-checker"
  eyebrow={"Knowledge Base · Email · Tool"}
  h1={"Email Deliverability Checker"}
  tagline={"Enter a domain. We run live DNS lookups for SPF, DMARC, and DKIM, score what we find, and tell you the single biggest thing to fix. All in your browser, nothing is sent to us."}
>
  <Fragment set:html={STAGE} />
  <Fragment slot="explainer" set:html={EXPLAINER} />
  <script is:inline set:html={TOOLJS} />
</ToolPage>
