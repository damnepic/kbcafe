---
import Layout from '../layouts/Layout.astro';
import { TOOLS } from '../data/tools.js';
---
<Layout
  title="KB Cafe — a developer’s knowledge base"
  description="Fast, clean developer tools and quick references — freshly brewed. Everything runs in your browser: nothing uploaded, nothing tracked."
  path="/"
>
  <header>
    <div class="eyebrow">☕ the developer&rsquo;s knowledge base</div>
    <h1>
      <span class="l1">Tools &amp; references,</span>
      <span class="l2"><span class="mk">freshly brewed.</span></span>
    </h1>
    <p class="sub">Fast, clean developer tools and quick references — all in one place. Everything runs in your browser: nothing uploaded, nothing tracked.</p>

    <a class="pick" href="/json-to-typescript">
      <span class="cup"><svg><use href="#cup"/></svg></span>
      <div class="body">
        <span class="tag">Today&rsquo;s pick</span>
        <span class="txt">Turn any JSON into a typed <b>TypeScript</b> interface in one paste.</span>
      </div>
      <span class="go">open →</span>
    </a>

    <form class="finder" onsubmit="return false">
      <span class="ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></span>
      <input id="q" type="text" placeholder="What do you need?  try “json to typescript”, “cron”, “jwt”…" autocomplete="off" />
      <button type="submit">Brew →</button>
    </form>

    <div class="cats" id="cats">
      <button class="cat active" data-c="all">All</button>
      <button class="cat" data-c="json">JSON</button>
      <button class="cat" data-c="encoding">Encoding</button>
      <button class="cat" data-c="time">Time &amp; Cron</button>
      <button class="cat" data-c="convert">Converters</button>
      <button class="cat" data-c="text">Text</button>
      <button class="cat" data-c="feeds">Feeds</button>
    </div>
  </header>

  <section id="menu">
    <div class="menu-head">
      <h2>On the <i>menu</i></h2>
      <span class="count" id="count"></span>
    </div>
    <div class="grid" id="grid"></div>
  </section>

  <script define:vars={{ TOOLS }}>
    const grid = document.getElementById('grid'), countEl = document.getElementById('count');
    let activeCat = "all", query = "";

    function render(){
      const q = query.trim().toLowerCase();
      const list = TOOLS.filter(t => {
        const catOk = activeCat === "all" || t.cat === activeCat;
        const qOk = !q || (t.nm + " " + t.ds + " " + t.ctl).toLowerCase().includes(q);
        return catOk && qOk;
      });
      grid.innerHTML = "";
      if(!list.length){
        grid.innerHTML = `<div class="none"><svg><use href="#kb-mark-mini"/></svg>No tool for that yet — but it could be next on the menu. ☕</div>`;
        countEl.textContent = "0 tools"; return;
      }
      list.forEach((t, i) => {
        const live = !!t.href;
        const el = document.createElement(live ? 'a' : 'div');
        if(live) el.href = t.href;
        el.className = "card " + t.color + (live ? "" : " soon");
        el.style.animationDelay = (i * 0.04) + "s";
        el.innerHTML = `${t.heritage ? '<svg class="heritage"><use href="#cup"/></svg>' : ''}
          <div class="ct">${t.ctl}</div><div class="nm">${t.nm}</div>
          <div class="ds">${t.ds}</div>
          <div class="dm">${live ? 'kbcafe.com' : 'soon on the menu'}</div>`;
        grid.appendChild(el);
      });
      countEl.textContent = list.length + " tool" + (list.length > 1 ? "s" : "");
    }
    document.getElementById('q').addEventListener('input', e => { query = e.target.value; render(); });
    document.getElementById('cats').addEventListener('click', e => {
      const btn = e.target.closest('.cat'); if(!btn) return;
      document.querySelectorAll('.cat').forEach(c => c.classList.remove('active'));
      btn.classList.add('active'); activeCat = btn.dataset.c; render();
    });
    render();
  </script>
</Layout>

<style>
  body::after{content:"";position:absolute;top:-220px;left:50%;transform:translateX(-50%);
    width:1100px;height:680px;z-index:0;pointer-events:none;
    background:radial-gradient(ellipse at center,rgba(244,180,35,.30),rgba(244,132,42,.12) 42%,transparent 70%);filter:blur(8px)}

  header{text-align:center;padding:54px 0 18px}
  .eyebrow{font-family:var(--font-mono);font-size:12.5px;font-weight:700;letter-spacing:.18em;
    text-transform:uppercase;color:var(--coral);margin-bottom:22px;opacity:0;animation:rise .7s .05s forwards}
  h1{font-family:var(--font-display);font-weight:800;letter-spacing:-.035em;line-height:.96;
    font-size:clamp(44px,7.4vw,86px);color:var(--ink)}
  h1 .l1{display:block;opacity:0;animation:rise .8s .12s forwards}
  h1 .l2{display:block;opacity:0;animation:rise .8s .22s forwards}
  .mk{position:relative;white-space:nowrap;z-index:1}
  .mk::before{content:"";position:absolute;inset:6% -3% 8% -3%;z-index:-1;background:var(--gold);transform:rotate(-1.6deg);border-radius:6px}
  .sub{margin:26px auto 0;max-width:560px;font-size:18px;color:var(--ink-soft);line-height:1.5;opacity:0;animation:rise .8s .32s forwards}

  .pick{max-width:580px;margin:34px auto 0;background:var(--ink);color:var(--cream);border-radius:18px;
    padding:14px 20px 14px 16px;display:flex;align-items:center;gap:15px;text-align:left;text-decoration:none;
    box-shadow:var(--shadow);opacity:0;animation:rise .8s .4s forwards;transition:transform .18s,box-shadow .18s}
  .pick:hover{transform:translateY(-2px);box-shadow:12px 14px 0 rgba(30,24,19,.1)}
  .pick .cup{flex-shrink:0}
  .pick .cup svg{width:42px;height:42px;display:block}
  .pick .body{flex:1}
  .pick .tag{font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.14em;
    text-transform:uppercase;color:var(--gold);display:block;margin-bottom:3px}
  .pick .txt{font-size:14.5px;line-height:1.35}
  .pick .txt b{font-family:var(--font-mono);color:var(--gold);font-weight:700}
  .pick .go{font-family:var(--font-mono);font-size:13px;font-weight:700;color:var(--cream);white-space:nowrap}
  .pick:hover .go{color:var(--gold)}

  .finder{max-width:600px;margin:18px auto 0;background:var(--cream);border:1.5px solid var(--ink);
    border-radius:18px;padding:9px 9px 9px 18px;display:flex;align-items:center;gap:12px;
    box-shadow:var(--shadow);opacity:0;animation:rise .8s .48s forwards;transition:box-shadow .2s,transform .2s}
  .finder:focus-within{box-shadow:10px 10px 0 var(--coral);transform:translateY(-1px)}
  .finder .ic{color:var(--coral);flex-shrink:0;display:grid;place-items:center}
  .finder input{flex:1;border:0;outline:0;background:transparent;font-family:var(--font-body);
    font-size:16.5px;font-weight:500;color:var(--ink);padding:10px 0}
  .finder input::placeholder{color:#b3a48f}
  .finder button{font-family:var(--font-display);font-weight:700;font-size:15px;color:var(--cream);
    background:var(--coral);border:0;border-radius:12px;padding:13px 20px;cursor:pointer;display:flex;
    align-items:center;gap:7px;transition:background .15s,transform .12s}
  .finder button:hover{background:var(--coral-deep)}
  .finder button:active{transform:scale(.96)}

  .cats{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin:26px auto 0;max-width:680px;opacity:0;animation:rise .8s .56s forwards}
  .cat{font-family:var(--font-mono);font-size:12px;font-weight:500;letter-spacing:.04em;color:var(--ink-soft);
    background:transparent;border:1px solid var(--line);border-radius:20px;padding:8px 15px;cursor:pointer;transition:all .15s;text-transform:uppercase}
  .cat:hover{border-color:var(--ink);color:var(--ink)}
  .cat.active{background:var(--ink);color:var(--cream);border-color:var(--ink)}

  .menu-head{display:flex;align-items:baseline;justify-content:space-between;margin:64px 0 22px}
  .menu-head h2{font-family:var(--font-display);font-weight:800;font-size:30px;letter-spacing:-.02em}
  .menu-head h2 i{color:var(--coral);font-style:normal}
  .menu-head .count{font-family:var(--font-mono);font-size:12.5px;color:var(--ink-soft)}
  .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;padding-bottom:30px}
  .grid :global(.card){border-radius:18px;padding:20px 19px 17px;min-height:178px;display:flex;flex-direction:column;
    cursor:pointer;border:1.5px solid transparent;text-decoration:none;color:inherit;
    transition:transform .18s cubic-bezier(.2,.8,.2,1),box-shadow .18s;position:relative;overflow:hidden;
    opacity:0;animation:rise .6s forwards}
  .grid :global(.card:hover){transform:translateY(-5px) rotate(-.5deg);box-shadow:10px 12px 0 rgba(30,24,19,.12)}
  .grid :global(.card.soon){cursor:default}
  .grid :global(.card.soon:hover){transform:none;box-shadow:none;opacity:.78}
  .grid :global(.card .ct){font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;opacity:.7;margin-bottom:auto}
  .grid :global(.card .nm){font-family:var(--font-mono);font-weight:700;font-size:18px;letter-spacing:-.01em;margin:14px 0 7px;line-height:1.1}
  .grid :global(.card .ds){font-size:13.5px;line-height:1.4;opacity:.85}
  .grid :global(.card .dm){font-family:var(--font-mono);font-size:10.5px;margin-top:13px;opacity:.55}
  .grid :global(.c-coral){background:var(--coral);color:var(--cream)} .grid :global(.c-coral .ct){color:var(--gold);opacity:1}
  .grid :global(.c-gold){background:var(--gold);color:var(--ink)}
  .grid :global(.c-ink){background:var(--ink);color:var(--cream)} .grid :global(.c-ink .ct){color:var(--gold);opacity:1} .grid :global(.c-ink .nm){color:var(--gold)}
  .grid :global(.c-cream){background:var(--cream);color:var(--ink);border-color:var(--line)} .grid :global(.c-cream .ct){color:var(--coral);opacity:1}
  .grid :global(.heritage){position:absolute;top:12px;right:13px;width:17px;height:17px;opacity:.9}
  .grid :global(.none){grid-column:1/-1;text-align:center;font-family:var(--font-mono);color:var(--ink-soft);font-size:14px;padding:30px 0;display:flex;flex-direction:column;align-items:center;gap:14px}
  .grid :global(.none svg){width:46px;height:46px;opacity:.75}

  @media(max-width:860px){.grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:520px){.grid{grid-template-columns:1fr}
    .pick{flex-direction:row}.pick .cup svg{width:34px;height:34px}h1{font-size:clamp(38px,11vw,52px)}}
</style>
