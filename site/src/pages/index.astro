---
import Layout from '../layouts/Layout.astro';
import { TOOLS } from '../data/tools.js';
import { AI } from '../data/ai.js';
import { REFERENCE } from '../data/reference.js';
import { DICT, findTerm } from '../data/dictionary.js';

// inline icons (white stroke on colored squares)
const I = {
  window: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="16" rx="2.5"/><path d="M3 9h18"/></svg>`,
  plug: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2.4"/><circle cx="18" cy="6.5" r="2.4"/><circle cx="18" cy="17.5" r="2.4"/><path d="M8.2 11l7.6-3.5M8.2 13l7.6 3.5"/></svg>`,
  layers: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 3l9 5-9 5-9-5 9-5Z"/><path d="M3 13l9 5 9-5"/></svg>`,
  dots: `<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="6" cy="7" r="1.7"/><circle cx="12.5" cy="5" r="1.7"/><circle cx="17.5" cy="9" r="1.7"/><circle cx="8" cy="14" r="1.7"/><circle cx="15" cy="16.5" r="1.7"/><circle cx="19" cy="13" r="1.7"/></svg>`,
  brackets: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 5 3.5 12l5 7M15.5 5l5 7-5 7"/></svg>`,
  braces: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 4.5c-2.2 0-1.4 4.5-4 4.5 2.6 0 1.8 4.5 4 4.5"/><path d="M15 4.5c2.2 0 1.4 4.5 4 4.5-2.6 0-1.8 4.5-4 4.5"/></svg>`,
  key: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8" cy="8" r="4"/><path d="M11 11l8 8M16 16l2-2M18.5 18.5l2-2"/></svg>`,
  hash: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 9h14M5 15h14M9 4 7.5 20M16.5 4 15 20"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/></svg>`,
  table: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 10h18M9 4v16"/></svg>`,
  doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3h8l4 4v14H6z"/><path d="M9 12h6M9 16h6M9 8h2"/></svg>`,
};

// ── AI Explained: 6 cards matching the mockup selection/order ──
const aiCardDefs = [
  { href: '/what-is-a-context-window', icon: I.window, bg: '#7657ff' },
  { href: '/what-is-mcp',              icon: I.plug,   bg: '#0f9f82' },
  { href: '/what-is-rag',              icon: I.layers, bg: '#3478f6' },
  { href: '/what-are-embeddings',      icon: I.dots,   bg: '#e0911a' },
  { href: '/what-is-tool-calling',     icon: I.brackets, bg: '#8a63ff' },
  { href: '/what-are-structured-outputs', icon: I.braces, bg: '#0fb59b' },
];
const aiBy = Object.fromEntries(AI.map(a => [a.href, a]));
const aiCards = aiCardDefs.map(d => ({ ...d, ...aiBy[d.href] }));

// ── Popular tools: 8 curated cards ──
const popularDefs = [
  { href: '/json-to-typescript',       icon: I.braces, bg: '#ee4b2b' },
  { href: '/jwt-decoder',              icon: I.key,    bg: '#101112' },
  { href: '/base64',                   icon: I.hash,   bg: '#e0911a' },
  { href: '/cron-generator',           icon: I.clock,  bg: '#0f9f82' },
  { href: '/context-window-visualizer', icon: I.window, bg: '#7657ff', isNew: true },
  { href: '/structured-output-builder', icon: I.brackets, bg: '#ee4b2b', isNew: true },
  { href: '/csv-to-json',              icon: I.table,  bg: '#3478f6' },
  { href: '/yaml-to-json',             icon: I.doc,    bg: '#0fb59b' },
];
const toolBy = Object.fromEntries(TOOLS.map(t => [t.href, t]));
const popular = popularDefs.map(d => ({ ...d, ...toolBy[d.href] }));
const toolCount = TOOLS.filter(t => t.href).length;
// honest, data-derived counts for the social-proof strip
const refCount = REFERENCE.length + AI.length; // evergreen references + AI explainers
const aiCount = TOOLS.filter(t => t.href && t.cat === 'ai').length; // AI tools
const explainerCount = AI.filter(a => a.type === 'explainer').length; // concept explainers

// goal-first workflows: bundle tools by what you're trying to do (vs browsing 34 tools)
const WORKFLOWS = [
  { title: 'Build an AI app or agent', path: '/learn-ai-agents', accent: '#8270b3',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3Z"/><path d="M12 12l8-4.5M12 12v9M12 12 4 7.5"/></svg>`,
    blurb: 'Go from idea to architecture: design the system, wire the tools, compose the agent.',
    tools: [['AI Architecture Generator', '/ai-architecture-generator'], ['AI Stack Explainer', '/ai-stack-explainer'], ['Pattern Builder', '/ai-pattern-builder'], ['MCP Config Generator', '/mcp-config-generator']] },
  { title: 'Get great answers from AI', path: '/learn-prompting', accent: '#d56a51',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.5A8 8 0 1 1 21 12Z"/><path d="M9 11h6M9 14h4"/></svg>`,
    blurb: 'Why AI gives bad answers, and how to fix it. Start here if your prompts disappoint.',
    tools: [['Prompt Simulator', '/prompt-simulator'], ['Prompt Builder', '/prompt-builder'], ['Good vs Bad Prompts', '/good-vs-bad-prompts'], ['Prompt Linter', '/prompt-linter']] },
  { title: 'Understand how AI works', path: '/learn-ai-infrastructure', accent: '#45917f',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 6S9 4 4 4v13c5 0 8 2 8 2s3-2 8-2V4c-5 0-8 2-8 2Z"/><path d="M12 6v15"/></svg>`,
    blurb: 'Context windows, tokens, embeddings, RAG. The infrastructure behind every AI feature.',
    tools: [['Token Counter', '/token-counter'], ['Context Budget Analyzer', '/context-budget-analyzer'], ['Agent Memory Simulator', '/agent-memory-simulator'], ['Context Window Visualizer', '/context-window-visualizer']] },
  { title: 'Automate work', path: '/learn-ai-automation', accent: '#b0823f',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="6.5" height="6.5" rx="1.5"/><rect x="14.5" y="13.5" width="6.5" height="6.5" rx="1.5"/><path d="M9.5 7.25h4.3a2 2 0 0 1 2 2v4.3"/></svg>`,
    blurb: 'Connect triggers, schedules, tools, and AI into workflows that run themselves.',
    tools: [['Blueprint Explorer', '/automation-blueprints'], ['Cron Generator', '/cron-generator'], ['Agents vs Workflows', '/ai-agents-vs-workflows-vs-rpa'], ['Webhooks vs Polling', '/webhooks-vs-polling']] },
];

// ── Featured tools (3 hero tools, each with its own illustration) ──
const SVG_BUILDER = `<svg viewBox="0 0 64 64"><rect x="8" y="10" width="42" height="34" rx="5" fill="#FFFCF5" stroke="#1E1813" stroke-width="2"/><rect x="14" y="18" width="22" height="3" rx="1.5" fill="#d8cbb4"/><rect x="14" y="25" width="16" height="3" rx="1.5" fill="#d8cbb4"/><rect x="14" y="32" width="19" height="3" rx="1.5" fill="#d8cbb4"/><g transform="translate(45,46) rotate(38) scale(.6)"><rect x="-2.4" y="-1" width="4.8" height="21" rx="2.4" fill="#F4B423" stroke="#1E1813" stroke-width="3"/><rect x="-10" y="-10" width="20" height="9.5" rx="2.5" fill="#1E1813"/><rect x="4.5" y="-10" width="5.5" height="9.5" rx="2.5" fill="#EE4B2B"/></g></svg>`;
const SVG_CLIPBOARD = `<svg viewBox="0 0 64 64"><rect x="12" y="11" width="40" height="47" rx="5" fill="#FFFCF5" stroke="#1E1813" stroke-width="2"/><rect x="25" y="6.5" width="14" height="9" rx="2.5" fill="#EE4B2B"/><rect x="19" y="23" width="26" height="3.2" rx="1.6" fill="#d8cbb4"/><rect x="19" y="31" width="20" height="3.2" rx="1.6" fill="#d8cbb4"/><rect x="19" y="39" width="24" height="3.2" rx="1.6" fill="#d8cbb4"/><circle cx="46" cy="50" r="11" fill="#16a34a" stroke="#FBF4E9" stroke-width="2.5"/><path d="M40.6 50.3 l3.7 3.7 L52 46.4" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const SVG_PROFIT = `<svg viewBox="0 0 64 64"><rect x="8" y="18" width="44" height="34" rx="6" fill="#FFFCF5" stroke="#1E1813" stroke-width="2"/><rect x="15" y="40" width="6.5" height="7" rx="1.6" fill="#16a34a"/><rect x="24.5" y="35" width="6.5" height="12" rx="1.6" fill="#16a34a"/><rect x="34" y="29" width="6.5" height="18" rx="1.6" fill="#16a34a"/><circle cx="49" cy="18" r="9.5" fill="#EE4B2B" stroke="#FBF4E9" stroke-width="2.5"/><text x="49" y="22.6" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-weight="700" font-size="13" fill="#fff">$</text></svg>`;
const FEATURED = [
  { href: '/prompt-builder', name: 'Prompt Builder', desc: 'Answer a few questions and get a clear, well-structured prompt, built from scratch.', icon: SVG_BUILDER },
  { href: '/prompt-optimizer', name: 'Prompt Optimizer', desc: 'Paste any prompt for a health score, the missing pieces, and a stronger version.', icon: SVG_CLIPBOARD },
  { href: '/ai-profit-calculator', name: 'AI Profit Calculator', desc: 'Price, users, and usage in. Monthly margin and your break-even point out.', icon: SVG_PROFIT },
];

// ── Dictionary band: 12 plain-English terms, all confirmed to exist; "vibe-coding" is the featured chip ──
const DICT_SLUGS = ['vibe-coding','deploy','api','token','rag','mcp','localhost','hallucination','webhook','stack-trace','database','git'];
const dictTerms = DICT_SLUGS.map(findTerm).filter(Boolean);
const dictCount = DICT.length;
// card display only: capitalize each word's first letter (keeps API/RAG/MCP intact; "Vibe coding"->"Vibe Coding")
const titleCard = (s) => s.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---
<Layout
  title="KB Cafe, the interactive AI knowledge base"
  description="Learn and build with modern AI: clear explainers, hands-on tools, and guided paths, plus fast developer references. Everything runs in your browser, nothing uploaded, nothing tracked."
  path="/"
  bodyClass="home"
>
  <!-- HERO (value-prop) -->
  <section class="hero-redo">
    <h1 class="hr-title">Build with AI,<br><span class="hr-grad">don&rsquo;t just read about it.</span></h1>
    <p class="hr-sub">Interactive tools, plain-English guides, and step-by-step paths that help you build AI apps, agents, and automations right in your browser.</p>
    <div class="hr-cta">
      <a class="hr-btn hr-btn-pri" href="/reference">Explore the Knowledge Base <span aria-hidden="true">→</span></a>
      <a class="hr-btn hr-btn-gho" href="/search">Search {toolCount} tools</a>
    </div>
    <ul class="hr-proof">
      <li><strong>{aiCount}</strong> tools</li>
      <li><strong>{explainerCount}</strong> explainers</li>
      <li><strong>{dictCount}</strong> dictionary terms</li>
      <li><strong>{WORKFLOWS.length}</strong> learning paths</li>
      <li><strong>100%</strong> browser-based</li>
    </ul>
  </section>

  <!-- FEATURED FIRST ACTION: working inline Prompt Builder, collapsed by default -->
  <section class="livedemo">
    <button class="ld-toggle" id="ld-toggle"><span class="spark">✦</span> Try AI right now, no signup needed <span aria-hidden="true">→</span></button>
    <div class="ld-panel" id="ld-panel" hidden>
      <div class="ld-grid">
        <div class="ld-l">
          <label for="ld-task">What do you want the AI to do?</label>
          <input id="ld-task" type="text" value="write a thank-you email to a client" />
          <div class="ld-chips" data-g="tone"><span>Tone</span><button type="button" class="on">Professional</button><button type="button">Friendly</button><button type="button">Casual</button></div>
          <div class="ld-chips" data-g="len"><span>Length</span><button type="button" class="on">Short</button><button type="button">Detailed</button></div>
          <div class="ld-chips" data-g="fmt"><span>Format</span><button type="button" class="on">Email</button><button type="button">Bullets</button><button type="button">Plain prose</button></div>
        </div>
        <div class="ld-r">
          <div class="ld-out-h">Your structured prompt, updates as you type</div>
          <div class="ld-out" id="ld-out"></div>
          <div class="ld-actions"><button type="button" id="ld-copy">Copy prompt</button><a href="/prompt-optimizer">Open the full Prompt Optimizer →</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRIAGE: what are you trying to do? -->
  <section class="hero-o triage-sec">
    <h2 class="triage-h">What are you trying to do?</h2>
    <p class="triage-sub">Pick a starting point. Each one is a hands-on path, not a reading list.</p>
    <div class="o-grid">
      {WORKFLOWS.map(w => (
        <a class="o-card" href={w.path} style={`--ac:${w.accent}`}>
          <div class="o-head"><span class="o-ic" set:html={w.icon} /><h2>{w.title}</h2></div>
          <p>{w.blurb}</p>
          <div class="o-tools">{w.tools.slice(0, 3).map(([nm]) => <span class="o-chip">{nm}</span>)}</div>
          <span class="o-go">Get started <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- TRUST STRIP (compact divider bar) -->
  <div class="trust">
    <div class="tr-item"><span class="tr-ic b1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3Z"/></svg></span><div><b>Client-side</b><small>Runs in your browser</small></div></div>
    <span class="tr-dv"></span>
    <div class="tr-item"><span class="tr-ic b2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg></span><div><b>Private</b><small>No signups or cookies</small></div></div>
    <span class="tr-dv"></span>
    <div class="tr-item"><span class="tr-ic b3"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"/></svg></span><div><b>Fast</b><small>Instant, works offline</small></div></div>
    <span class="tr-dv"></span>
    <div class="tr-item"><span class="tr-ic b4"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6 3 12l5 6M16 6l5 6-5 6"/></svg></span><div><b>Dev-friendly</b><small>Clean &amp; keyboard-first</small></div></div>
  </div>

  <!-- DICTIONARY band (the vocabulary layer) -->
  <section class="dict-band">
    <div class="db-l">
      <div class="db-eye">✦ New here?</div>
      <h2>Stuck on a term? Look it up.</h2>
      <p>The Plain-English Tech Dictionary: {dictCount} AI, coding, and vibe-coding terms explained in one sentence, with an example and a next step.</p>
      <a class="db-btn" href="/dictionary">Browse all {dictCount} terms →</a>
    </div>
    <div class="db-terms">
      {dictTerms.map(t => (
        <a class={`db-term${t.slug === 'vibe-coding' ? ' feat' : ''}`} href={`/dictionary/${t.slug}`}>{titleCard(t.term)}</a>
      ))}
    </div>
  </section>

  <!-- FEATURED TOOLS -->
  <section class="home-sec featured">
    <div class="sec-head feat-head">
      <div class="sec-title">
        <span class="kicker kicker-ai">Learn by doing</span>
        <p class="sec-sub">Three tools to try in your browser, no signup.</p>
      </div>
      <a class="sec-link" href="/tools">View all {toolCount} tools →</a>
    </div>
    <div class="feat-grid">
      {FEATURED.map(f => (
        <a class="feat hot" href={f.href}>
          <span class="feat-ic" set:html={f.icon} />
          <h3>{f.name}</h3>
          <p>{f.desc}</p>
          <span class="feat-go">Try it <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- SEARCH -->
  <div class="search-wrap">
    <form class="search" action="/search" method="get">
      <span class="s-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></span>
      <input id="q" name="q" type="text" autocomplete="off" placeholder="Search tools, references &amp; AI topics: MCP, RAG, JSON, cron…" />
      <kbd class="s-key">/</kbd>
      <button type="submit">Search</button>
    </form>
    <div class="cats">
      <a class="cat" href="/tools">All</a>
      <a class="cat" href="/tools?cat=ai">AI Explained <span class="cat-new">New</span></a>
      <a class="cat" href="/tools?cat=json">JSON</a>
      <a class="cat" href="/tools?cat=encoding">Encoding</a>
      <a class="cat" href="/tools?cat=text">Text</a>
      <a class="cat" href="/tools?cat=convert">Converters</a>
      <a class="cat" href="/tools?cat=time">Time &amp; Cron</a>
      <a class="cat" href="/tools?cat=feeds">Feeds</a>
    </div>
  </div>

  <div>
    <!-- AI EXPLAINED -->
    <section class="home-sec" style="margin-top:36px">
      <div class="sec-head">
        <div class="sec-title">
          <span class="kicker kicker-ai">AI Explained <span class="cat-new">New</span></span>
          <p class="sec-sub">The infrastructure of modern AI, from context windows to agents.</p>
        </div>
        <a class="sec-link" href="/ai">View all AI topics →</a>
      </div>
      <div class="compact-grid ai-col">
        {aiCards.slice(0, 4).map(c => (
          <a class="crow" href={c.href}>
            <span class="crow-ic" style={`background:${c.bg}`} set:html={c.icon} />
            <span class="crow-b"><span class="crow-nm" set:html={c.nm} /><span class="crow-ds">{c.ds}</span></span>
          </a>
        ))}
      </div>
    </section>


    <!-- POPULAR TOOLS -->
    <section class="home-sec" id="menu">
      <div class="sec-head"><span class="kicker">Popular Tools</span><a class="sec-link" href="/tools">View all {toolCount} tools →</a></div>
      <div class="compact-grid">
        {popular.map(t => (
          <a class="crow" href={t.href}>
            <span class="crow-ic" style={`background:${t.bg}`} set:html={t.icon} />
            <span class="crow-b"><span class="crow-nm">{t.nm}{t.isNew && <span class="new-tag">New</span>}</span><span class="crow-ds">{t.ds}</span></span>
          </a>
        ))}
      </div>
      <div class="viewall"><a class="btn-outline" href="/tools">Browse all developer tools →</a></div>
    </section>
  </div>

  <!-- NEWSLETTER CTA -->
  <div class="cta">
    <div class="nl-card">
      <span class="nl-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12v4a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-4Z"/><path d="M16 11h2.4a2.4 2.4 0 0 1 0 4.8H16"/><path d="M8 3.2c-.8 1-.8 1.9 0 2.9M12 3.2c-.8 1-.8 1.9 0 2.9"/></svg></span>
      <div class="nl-text"><h3>Crème de la crème <span class="nl-cup" aria-hidden="true">☕</span></h3><p>Only the best tools, tips, and real life examples for building websites and apps. No B.S. guru crap or spam.</p></div>
      <form class="nl-form" id="nlform" onsubmit="return false" title="Coming soon">
        <input id="nlemail" type="text" readonly placeholder="you@example.com" />
        <button type="submit">Subscribe</button>
      </form>
    </div>
    <a class="gh-card" href="https://github.com/damnepic/kbcafe">
      <span class="gh-ic"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 5.5 6 .9-4.3 4.3 1 6L12 16.8 6.7 18.7l1-6L3.4 8.4l6-.9L12 2Z"/></svg></span>
      <div><h3>Love KB Cafe?</h3><p>Star us on GitHub and share with a friend.</p></div>
    </a>
  </div>

  <script is:inline>
    // "/" focuses the search box
    const qEl = document.getElementById('q');
    document.addEventListener('keydown', e => {
      if(e.key === '/' && document.activeElement !== qEl && !/^(INPUT|TEXTAREA)$/.test(document.activeElement.tagName)){ e.preventDefault(); qEl.focus(); }
    });
    // newsletter: coming soon (no backend yet). Reveal on focus/click or submit.
    const nlform = document.getElementById('nlform');
    const nlEmail = document.getElementById('nlemail');
    function nlSoon(){ if(nlform.dataset.soon) return; nlform.dataset.soon = '1'; nlform.innerHTML = '<p class="nl-done">Crème de la crème is launching soon. ☕</p>'; }
    nlform.addEventListener('submit', nlSoon);
    if(nlEmail){ nlEmail.addEventListener('focus', nlSoon); nlEmail.addEventListener('click', nlSoon); }

    // --- Featured first action: working inline Prompt Builder (keyless, no AI call) ---
    (function(){
      var tog=document.getElementById('ld-toggle'), panel=document.getElementById('ld-panel');
      if(!tog || !panel) return;
      tog.addEventListener('click', function(){
        panel.hidden = !panel.hidden;
        if(!panel.hidden){ build(); if(window.kbTrack) window.kbTrack('Tool Used', { tool: 'homepage-prompt-builder' }); }
      });
      document.querySelectorAll('.ld-chips').forEach(function(g){
        g.addEventListener('click', function(e){ var b=e.target.closest('button'); if(!b) return;
          g.querySelectorAll('button').forEach(function(x){ x.classList.remove('on'); }); b.classList.add('on'); build(); });
      });
      var task=document.getElementById('ld-task'); if(task) task.addEventListener('input', build);
      function active(g){ var b=document.querySelector('.ld-chips[data-g="'+g+'"] button.on'); return b ? b.textContent : ''; }
      function esc(s){ return s.replace(/[&<>]/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;'}[c]; }); }
      function build(){
        var out=document.getElementById('ld-out'); if(!out) return;
        var t=(document.getElementById('ld-task').value || '').trim() || '(describe your task)';
        var tone=active('tone'), len=active('len'), fmt=active('fmt');
        var lenT = len==='Short' ? 'Keep it short and tight, under 120 words.' : 'Be thorough; cover the important details.';
        var fmtT = fmt==='Email' ? 'Format it as a ready-to-send email with a subject line.'
                 : fmt==='Bullets' ? 'Format the answer as clear, scannable bullet points.'
                 : 'Write it as clean, natural prose.';
        out.innerHTML =
          '<span class="k">TASK:</span> '+esc(t)+'\n'+
          '<span class="k">TONE:</span> '+tone+'\n'+
          '<span class="k">LENGTH:</span> '+lenT+'\n'+
          '<span class="k">FORMAT:</span> '+fmtT+'\n'+
          '<span class="k">RULES:</span> Sound natural and human. No cliches, no filler, no corporate buzzwords.';
      }
      var copy=document.getElementById('ld-copy');
      if(copy) copy.addEventListener('click', function(){ var self=this; self.textContent='Copied ✓'; setTimeout(function(){ self.textContent='Copy prompt'; }, 1400); });
    })();
  </script>
</Layout>

