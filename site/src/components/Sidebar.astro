---
// Docs-style utility rail for content pages. Collapsible (remembered, localStorage),
// mobile = slide-in drawer. No tracking. `path` highlights the current page.
import { TOOLS } from '../data/tools.js';
import { LEARNING_PATHS } from '../data/learningPaths.js';
import { AI } from '../data/ai.js';
import { REFERENCE } from '../data/reference.js';
const { path = '', drawerOnly = false } = Astro.props;   // drawerOnly: no desktop rail, mobile drawer only (rail-less pages)
const aiTools = TOOLS.filter(t => t.href && t.cat === 'ai');
const explainers = AI.filter(a => a.type === 'explainer');

const I = {
  build: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3Z"/><path d="M12 12l8-4.5M12 12v9M12 12 4 7.5"/></svg>`,
  chat: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.5A8 8 0 1 1 21 12Z"/><path d="M9 11h6M9 14h4"/></svg>`,
  book: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M12 6S9 4 4 4v13c5 0 8 2 8 2s3-2 8-2V4c-5 0-8 2-8 2Z"/><path d="M12 6v15"/></svg>`,
  doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5M9 13h6M9 17h6"/></svg>`,
  tool: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.2 5.2L3 18l3 3 6.5-6.5a4 4 0 0 0 5.2-5.2l-2.6 2.6-2.3-2.3 2.6-2.6Z"/></svg>`,
  cap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4 2 9l10 5 10-5-10-5Z"/><path d="M6 11v5c0 1.1 2.7 2.5 6 2.5s6-1.4 6-2.5v-5"/></svg>`,
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>`,
  map: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M9 3 3 5v16l6-2 6 2 6-2V3l-6 2-6-2Z"/><path d="M9 3v16M15 5v16"/></svg>`,
  cards: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><rect x="3" y="7" width="13" height="14" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-2"/></svg>`,
  chevron: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>`,
  gear: `<svg viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M9.62 4.68 L10.37 1.73 L13.63 1.73 L14.38 4.68 L15.50 5.14 L18.11 3.59 L20.41 5.89 L18.86 8.50 L19.32 9.62 L22.27 10.37 L22.27 13.63 L19.32 14.38 L18.86 15.50 L20.41 18.11 L18.11 20.41 L15.50 18.86 L14.38 19.32 L13.63 22.27 L10.37 22.27 L9.62 19.32 L8.50 18.86 L5.89 20.41 L3.59 18.11 L5.14 15.50 L4.68 14.38 L1.73 13.63 L1.73 10.37 L4.68 9.62 L5.14 8.50 L3.59 5.89 L5.89 3.59 L8.50 5.14 Z M8.3 12 a3.7 3.7 0 1 0 7.4 0 a3.7 3.7 0 1 0 -7.4 0 Z"/></svg>`,
  briefcase: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 13h18"/></svg>`,
  spark: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/><path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/></svg>`,
};
const TRIAGE = [
  { label: 'New to AI?', ds: 'start from zero', href: '/beginner-ai', icon: I.spark, color: '#3478f6' },
  { label: 'Learn AI', ds: 'the fundamentals', href: '/learn-ai-infrastructure', icon: I.book },
  { label: 'Build AI Agents', ds: 'apps & agents', href: '/learn-ai-agents', icon: I.build },
  { label: 'Get Better Answers', ds: 'prompting', href: '/learn-prompting', icon: I.chat },
  { label: 'Code with AI', ds: 'write real code', href: '/learn-ai-coding', icon: I.tool },
  { label: 'Automation', ds: 'workflows & agents', href: '/learn-ai-automation', icon: I.gear },
  { label: 'AI Business', ds: 'grow & monetize', href: '/ai-business', icon: I.briefcase },
];
const active = (h) => h === path;
---
<aside class:list={["kb-sb", { "drawer-only": drawerOnly }]} id="kb-sb" aria-label="Site navigation">
  <div class="sb-bar">
    <a class="sb-search" href="/search"><span class="sb-ic" set:html={I.search} /><span class="sb-lbl">Search</span></a>
    <button class="sb-collapse" id="sb-collapse" type="button" aria-label="Collapse sidebar" title="Collapse"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m13 6-6 6 6 6M18 6l-6 6 6 6"/></svg></button>
    <button class="sb-close" id="sb-close" type="button" aria-label="Close menu" title="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg></button>
  </div>

  <nav class="sb-primary" aria-label="Main">
    <a class={active('/') ? 'on' : ''} href="/">Home</a>
    <a class={active('/reference') ? 'on' : ''} href="/reference">Knowledge Base</a>
    <a class={active('/tools') ? 'on' : ''} href="/tools">Tools</a>
    <a class={active('/learn') ? 'on' : ''} href="/learn">Learn</a>
  </nav>

  <nav class="sb-triage">
    <span class="sb-h">What are you doing?</span>
    {TRIAGE.map(t => t.soon ? (
      <span class="sb-item soon" title={`${t.label}, coming soon`}>
        <span class="sb-ic" set:html={t.icon} />
        <span class="sb-lbl"><b>{t.label}</b><small>coming soon</small></span>
      </span>
    ) : (
      <a class={`sb-item${active(t.href) ? ' on' : ''}`} href={t.href} title={`${t.label}, ${t.ds}`}>
        <span class="sb-ic" style={`color:${t.color || 'var(--coral)'}`} set:html={t.icon} />
        <span class="sb-lbl"><b>{t.label}</b><small>{t.ds}</small></span>
      </a>
    ))}
  </nav>

  <div class="sb-sec" data-sec="explained">
    <button class="sb-toggle" type="button" aria-expanded="false"><span class="sb-ic" set:html={I.book} /><span class="sb-lbl">AI Explained</span><span class="sb-chev" set:html={I.chevron} /></button>
    <div class="sb-list">
      {explainers.map(a => <a class={`sb-link${active(a.href) ? ' on' : ''}`} href={a.href}>{a.nm}</a>)}
      <a class="sb-all" href="/ai">All AI Explained →</a>
    </div>
  </div>

  <div class="sb-sec" data-sec="tools">
    <button class="sb-toggle" type="button" aria-expanded="false"><span class="sb-ic" set:html={I.tool} /><span class="sb-lbl">Use a tool</span><span class="sb-chev" set:html={I.chevron} /></button>
    <div class="sb-list">
      {aiTools.map(t => <a class={`sb-link${active(t.href) ? ' on' : ''}`} href={t.href}>{t.nm}</a>)}
      <a class="sb-all" href="/tools?cat=ai">All AI tools →</a>
    </div>
  </div>

  <div class="sb-sec" data-sec="lessons">
    <button class="sb-toggle" type="button" aria-expanded="false"><span class="sb-ic" set:html={I.cap} /><span class="sb-lbl">Learning paths</span><span class="sb-chev" set:html={I.chevron} /></button>
    <div class="sb-list">
      {LEARNING_PATHS.map(p => <a class={`sb-link${active(p.route) ? ' on' : ''}`} href={p.route}>{p.title}</a>)}
      <a class={`sb-link${active('/skill-tree') ? ' on' : ''}`} href="/skill-tree">Skill Tree</a>
      <a class="sb-all" href="/learn">All learning paths →</a>
    </div>
  </div>

  <div class="sb-sec" data-sec="refs">
    <button class="sb-toggle" type="button" aria-expanded="false"><span class="sb-ic" set:html={I.doc} /><span class="sb-lbl">References</span><span class="sb-chev" set:html={I.chevron} /></button>
    <div class="sb-list">
      {REFERENCE.map(r => <a class={`sb-link${active(r.href) ? ' on' : ''}`} href={r.href}>{r.nm}</a>)}
      <a class="sb-all" href="/reference">All references →</a>
    </div>
  </div>

  <div class="sb-foot">
    <a class={active('/flashcards') ? 'on' : ''} href="/flashcards" title="Flashcards"><span class="sb-ic" set:html={I.cards} /><span class="sb-lbl">Flashcards</span><span class="sb-new">New</span></a>
    <a class={active('/til') ? 'on' : ''} href="/til" title="Today I Learned"><span class="sb-ic" set:html={I.doc} /><span class="sb-lbl">Today I Learned</span><span class="sb-new">New</span></a>
    <a class={active('/resources') ? 'on' : ''} href="/resources" title="Free resources"><span class="sb-ic" set:html={I.briefcase} /><span class="sb-lbl">Free resources</span><span class="sb-new">New</span></a>
    <a class={active('/map') ? 'on' : ''} href="/map" title="Knowledge map"><span class="sb-ic" set:html={I.map} /><span class="sb-lbl">Knowledge map</span></a>
  </div>
</aside>

<style>
  .kb-sb{position:sticky;top:78px;align-self:start;width:260px;flex-shrink:0;max-height:calc(100vh - 92px);overflow-y:auto;
    background:var(--cream);border:1.2px solid var(--line);border-radius:16px;padding:12px 12px 14px;display:flex;flex-direction:column;gap:6px;
    scrollbar-width:thin}
  .sb-bar{display:flex;align-items:center;gap:8px;margin-bottom:4px}
  .sb-search{flex:1;display:flex;align-items:center;gap:9px;text-decoration:none;color:var(--ink-soft);border:1.2px solid var(--line);border-radius:10px;padding:8px 11px;font-family:var(--font-mono);font-size:13px;font-weight:600}
  .sb-search:hover{border-color:var(--ink);color:var(--ink)}
  .sb-collapse{display:grid;place-items:center;width:34px;height:34px;border-radius:9px;border:1.2px solid var(--line);background:var(--paper);color:var(--ink-soft);cursor:pointer;flex-shrink:0}
  .sb-collapse:hover{color:var(--coral);border-color:var(--coral)}
  .sb-collapse svg{width:17px;height:17px}

  .sb-h{font-family:var(--font-mono);font-size:9.5px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);padding:8px 6px 4px}
  .sb-ic{display:grid;place-items:center;width:20px;height:20px;flex-shrink:0}.sb-ic svg{width:18px;height:18px}
  .sb-triage{display:flex;flex-direction:column;gap:2px;padding-bottom:6px;border-bottom:1px solid var(--line)}
  .sb-item{display:flex;align-items:center;gap:11px;text-decoration:none;color:var(--ink);border-radius:10px;padding:8px 9px;transition:background .12s}
  .sb-item:hover{background:var(--paper-2)}
  .sb-item.on{background:#ffe5dd}
  .sb-item.soon{opacity:.5;cursor:default}
  .sb-item.soon .sb-ic{color:var(--ink-soft)}
  .sb-item.soon .sb-lbl small{color:var(--coral);opacity:.8;font-weight:700}
  .sb-item .sb-lbl{display:flex;flex-direction:column;line-height:1.15}
  .sb-item .sb-lbl b{font-family:var(--font-display);font-weight:800;font-size:14px}
  .sb-item .sb-lbl small{font-size:11px;color:var(--ink-soft)}

  .sb-sec{border-bottom:1px solid var(--line);padding:4px 0}
  .sb-toggle{width:100%;display:flex;align-items:center;gap:11px;background:none;border:0;cursor:pointer;color:var(--ink);border-radius:10px;padding:8px 9px;font-family:var(--font-display);font-weight:800;font-size:14px}
  .sb-toggle:hover{background:var(--paper-2)}
  .sb-toggle .sb-ic{color:var(--ink-soft)}
  .sb-chev{margin-left:auto;color:var(--ink-soft);transition:transform .18s}.sb-chev svg{width:16px;height:16px}
  .sb-sec.open .sb-chev{transform:rotate(180deg)}
  .sb-list{display:none;flex-direction:column;gap:1px;padding:2px 0 4px 8px}
  .sb-sec.open .sb-list{display:flex}
  .sb-link{text-decoration:none;color:var(--ink-soft);font-family:var(--font-mono);font-size:12.5px;padding:6px 8px 6px 23px;border-radius:8px;border-left:2px solid var(--line);margin-left:8px}
  .sb-link:hover{color:var(--ink);background:var(--paper-2)}
  .sb-link.on{color:var(--coral);border-left-color:var(--coral);font-weight:700;background:#ffe5dd}
  .sb-all{margin:4px 0 0 8px;padding:6px 8px;font-family:var(--font-display);font-weight:800;font-size:12px;color:var(--coral);text-decoration:none}

  .sb-foot{padding-top:4px}
  .sb-foot a{display:flex;align-items:center;gap:11px;text-decoration:none;color:var(--ink-soft);border-radius:10px;padding:8px 9px;font-family:var(--font-display);font-weight:700;font-size:13.5px}
  .sb-foot a:hover{background:var(--paper-2);color:var(--ink)}
  .sb-new{margin-left:auto;font-family:var(--font-mono);font-size:9px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#fff;background:var(--coral);border-radius:5px;padding:2px 6px;line-height:1.1}

  /* collapsed = icon rail (desktop). class lives on .kb-sb so scoped CSS reaches it */
  .kb-sb.collapsed{width:72px;padding:12px 10px;align-items:center}
  .kb-sb.collapsed .sb-lbl,.kb-sb.collapsed .sb-h,.kb-sb.collapsed .sb-chev,.kb-sb.collapsed .sb-list,.kb-sb.collapsed .sb-new{display:none}
  .kb-sb.collapsed .sb-bar{flex-direction:column;gap:6px}
  .kb-sb.collapsed .sb-collapse{transform:rotate(180deg)}
  .kb-sb.collapsed .sb-search{flex:none;width:40px;height:40px;justify-content:center;padding:0}
  .kb-sb.collapsed .sb-item,.kb-sb.collapsed .sb-toggle,.kb-sb.collapsed .sb-foot a{justify-content:center;padding:10px 0}
  .kb-sb.collapsed .sb-triage{align-items:center}

  /* primary site nav — surfaced only inside the mobile drawer (the desktop header already carries it),
     so the single drawer is a true superset of the old header menu + sidebar */
  .sb-primary{display:none}

  /* rail-less pages (homepage, map, beginner-ai…): no desktop rail, just the mobile drawer */
  .kb-sb.drawer-only{display:none}

  /* mobile = drawer */
  .sb-burger{display:none}
  .sb-close{display:none}
  @media(max-width:900px){
    .kb-sb.drawer-only{display:flex}
    .sb-primary{display:grid;grid-template-columns:1fr 1fr;gap:6px;padding:2px 2px 10px;margin-bottom:2px;border-bottom:1px solid var(--line)}
    .sb-primary a{text-align:center;text-decoration:none;font-family:var(--font-display);font-weight:800;font-size:13.5px;
      color:var(--ink);background:var(--paper-2);border-radius:9px;padding:11px 8px;transition:background .12s,color .12s}
    .sb-primary a:hover{background:#f0e3cf}
    .sb-primary a.on{background:#ffe5dd;color:var(--coral)}
    /* open BELOW the sticky header so the drawer's search + close aren't hidden behind it
       (the header sits in a higher-priority stacking context; --kb-navh is measured in JS) */
    .kb-sb{position:fixed;top:var(--kb-navh,64px);left:0;height:calc(100dvh - var(--kb-navh,64px));max-height:none;z-index:60;width:280px;border-radius:0;
      transform:translateX(-105%);transition:transform .25s;box-shadow:0 0 60px rgba(16,17,18,.3)}
    .kb-sb.drawer-open{transform:translateX(0)}
    /* on mobile the rail concept doesn't apply: always full drawer */
    .kb-sb.collapsed{width:280px;padding:12px;align-items:stretch}
    .kb-sb.collapsed .sb-lbl,.kb-sb.collapsed .sb-h{display:block}
    .kb-sb.collapsed .sb-search{flex:1;width:auto;height:auto;padding:8px 11px;justify-content:flex-start}
    .kb-sb.collapsed .sb-bar{flex-direction:row}
    .sb-collapse{display:none}
    .sb-close{display:grid;place-items:center;width:36px;height:36px;border-radius:9px;border:1.2px solid var(--line);
      background:var(--paper);color:var(--ink);cursor:pointer;flex-shrink:0}
    .sb-close svg{width:18px;height:18px}
  }
</style>

<script is:inline>
  (function () {
    const sb = document.getElementById('kb-sb'); if (!sb) return;
    const ls = { get: (k) => { try { return localStorage.getItem(k); } catch { return null; } }, set: (k, v) => { try { localStorage.setItem(k, v); } catch {} } };

    // overall collapse to icon rail (desktop), remembered. Class lives on the sidebar.
    if (ls.get('kb-sb-collapsed') === '1') sb.classList.add('collapsed');
    const collapseBtn = document.getElementById('sb-collapse');
    if (collapseBtn) collapseBtn.addEventListener('click', () => {
      const on = sb.classList.toggle('collapsed'); ls.set('kb-sb-collapsed', on ? '1' : '0');
    });

    // expandable sections, remembered
    sb.querySelectorAll('.sb-sec').forEach(sec => {
      const key = 'kb-sb-' + sec.dataset.sec;
      const saved = ls.get(key);
      // every section stays tucked by default; opens only if the user expanded it before
      if (saved === '1') sec.classList.add('open');
      const btn = sec.querySelector('.sb-toggle');
      btn.setAttribute('aria-expanded', sec.classList.contains('open'));
      btn.addEventListener('click', () => {
        // if collapsed to the rail, expand the rail first so the list is visible
        if (sb.classList.contains('collapsed') && window.innerWidth > 900) { sb.classList.remove('collapsed'); ls.set('kb-sb-collapsed', '0'); }
        const open = sec.classList.toggle('open'); ls.set(key, open ? '1' : '0'); btn.setAttribute('aria-expanded', open);
      });
    });

    // keep the drawer docked just under the sticky header (measured, so it adapts to header height)
    const setNavH = () => { const nav = document.querySelector('.site-nav'); if (nav) document.documentElement.style.setProperty('--kb-navh', nav.offsetHeight + 'px'); };
    setNavH(); window.addEventListener('resize', setNavH);

    // mobile drawer
    const burger = document.getElementById('sb-burger');
    const syncBurger = (open) => { if (burger) { burger.classList.toggle('open', open); burger.setAttribute('aria-expanded', open ? 'true' : 'false'); burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu'); } };
    const closeDrawer = () => { sb.classList.remove('drawer-open'); document.getElementById('sb-overlay') && document.getElementById('sb-overlay').classList.remove('on'); syncBurger(false); };
    if (burger) burger.addEventListener('click', () => {
      setNavH();
      const open = sb.classList.toggle('drawer-open');
      const ov = document.getElementById('sb-overlay'); if (ov) ov.classList.toggle('on', open);
      syncBurger(open);
    });
    const ov = document.getElementById('sb-overlay'); if (ov) ov.addEventListener('click', closeDrawer);
    const closeBtn = document.getElementById('sb-close'); if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sb.classList.contains('drawer-open')) closeDrawer(); });
    sb.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { if (window.innerWidth <= 900) closeDrawer(); }));
  })();
</script>
