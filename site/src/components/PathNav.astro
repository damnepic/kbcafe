---
// Learning-path continuation: a compact progress bar near the top and a big
// "STEP X OF Y → NEXT" component at the bottom of every step page. Reads path
// context from ?p=<id>&s=<index>; falls back to inferring the path from the URL.
// Fills the server-rendered #pn-top / #pn-bottom divs the layouts provide.
import { LEARNING_PATHS } from '../data/learningPaths.js';
import { TOOLS } from '../data/tools.js';
import { AI } from '../data/ai.js';
import { REFERENCE } from '../data/reference.js';

const labelOf = {};
TOOLS.forEach(t => { if (t.href) labelOf[t.href] = t.nm; });
AI.forEach(a => { labelOf[a.href] = a.nm; });
REFERENCE.forEach(r => { labelOf[r.href] = r.nm; });

const PATHS = {};
LEARNING_PATHS.forEach(p => {
  PATHS[p.id] = { id: p.id, route: p.route, title: p.shortTitle || p.title, steps: p.steps.map(h => ({ href: h, label: labelOf[h] || h })) };
});
---
<script is:inline define:vars={{ PATHS }}>
  (function () {
    const topEl = document.getElementById('pn-top');
    const botEl = document.getElementById('pn-bottom');
    if (!topEl && !botEl) return;
    const here = location.pathname.replace(/\/+$/, '') || '/';
    const qp = new URLSearchParams(location.search);
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const stepUrl = (id, i) => PATHS[id].steps[i].href + '?p=' + id + '&s=' + i;

    let path = null, idx = -1;
    const pid = qp.get('p');
    if (pid && PATHS[pid]) {
      path = PATHS[pid];
      const s = parseInt(qp.get('s'), 10);
      idx = Number.isInteger(s) ? s : path.steps.findIndex((st) => st.href === here);
    } else {
      const inP = Object.keys(PATHS).map((k) => PATHS[k]).filter((p) => p.steps.some((st) => st.href === here));
      if (inP.length === 1) { path = inP[0]; idx = path.steps.findIndex((st) => st.href === here); }
      else if (inP.length > 1) { renderChooser(inP); return; }
    }
    if (!path || idx < 0 || idx >= path.steps.length) return;

    const total = path.steps.length, n = idx + 1, last = idx === total - 1;

    // Progress is driven by what's actually been READ, not by position. A step is
    // marked read once the reader reaches ~70% of it (ReadingEnhancers.astro), which
    // then calls window.__kbPathNavRender() to live-refresh this component.
    // render() recomputes from kbProgress every time, so re-runs are cheap + correct.
    render();
    window.__kbPathNavRender = render;

    // When a learning path is active, PathNav's "Next unread" is the authoritative
    // forward step, so suppress the toolGraph's dark "NEXT step" hero (it can point
    // to a DIFFERENT target and double up the CTA). Cold/standalone tool pages have
    // no PathNav, so their dark card stays. The "Learn the concept" / "Related tools"
    // columns are untouched (not redundant with PathNav). tg-next is below the fold,
    // so hiding it after DOM-ready causes no visible flash.
    function hideTgNext() { var t = document.querySelector('.tg-next'); if (t) t.style.display = 'none'; }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', hideTgNext);
    else hideTgNext();

  function render() {
    const done = (window.kbProgress ? window.kbProgress.all() : new Set());
    const isRead = (h) => done.has(h);
    const doneCount = path.steps.filter((st) => isRead(st.href)).length;
    const pct = Math.round((doneCount / total) * 100);
    const allRead = doneCount >= total;
    const firstUnread = path.steps.findIndex((st) => !isRead(st.href));

    // analytics: Path Start (first step read) + Path Complete (all read), once per user per path
    try {
      const ps = 'kbcafe-ps-' + path.id, pc = 'kbcafe-pc-' + path.id;
      if (doneCount >= 1 && !localStorage.getItem(ps)) { localStorage.setItem(ps, '1'); window.kbTrack && window.kbTrack('Path Start', { path: path.id }); }
      if (allRead && !localStorage.getItem(pc)) { localStorage.setItem(pc, '1'); window.kbTrack && window.kbTrack('Path Complete', { path: path.id }); }
    } catch (e) {}

    if (topEl) {
      topEl.innerHTML =
        '<a class="pn-top-path" href="' + path.route + '">' + esc(path.title) + ' path</a>' +
        '<div class="pn-bar"><i style="width:' + pct + '%"></i></div>' +
        '<span class="pn-top-step">' + doneCount + ' of ' + total + ' read</span>';
      topEl.className = 'pn-top';
    }

    if (botEl) {
      if (allRead) {
        const others = Object.keys(PATHS).map((k) => PATHS[k]).filter((p) => p.id !== path.id);
        botEl.innerHTML =
          '<div class="pn-confetti">🎉</div>' +
          '<div class="pn-done-h">Path complete</div>' +
          '<p class="pn-done-sub">You&rsquo;ve read all ' + total + ' steps of <strong>' + esc(path.title) + '</strong>.</p>' +
          '<div class="pn-bar pn-bar-lg"><i style="width:100%"></i></div>' +
          '<div class="pn-continue-h">Continue learning</div>' +
          '<div class="pn-continue">' + others.map((p) => '<a href="' + p.route + '">' + esc(p.title) + ' &rarr;</a>').join('') + '</div>';
        botEl.className = 'pn-bottom pn-done';
      } else {
        const remaining = total - doneCount;
        const stepsList = path.steps.map((st, i) => {
          const read = isRead(st.href), hereStep = i === idx;
          return '<a class="pn-step' + (read ? ' is-read' : '') + (hereStep ? ' is-here' : '') + '" href="' + stepUrl(path.id, i) + '">' +
            '<span class="pn-step-dot">' + (read ? '&#10003;' : (i + 1)) + '</span>' +
            '<span class="pn-step-label">' + esc(st.label) + '</span>' +
            (hereStep ? '<span class="pn-step-here">You are here</span>' : (read ? '<span class="pn-step-tag">Read</span>' : '')) +
            '</a>';
        }).join('');
        const note = last
          ? '<p class="pn-note">This is the last step in the sequence, but you haven&rsquo;t read ' + remaining + ' of the ' + total + ' steps yet. Pick up the unread ones below to really finish the path.</p>'
          : '';
        const prev = idx > 0 ? '<a class="pn-prev" href="' + stepUrl(path.id, idx - 1) + '">&larr; Previous</a>' : '<span></span>';
        const nextBtn = firstUnread >= 0
          ? '<a class="pn-next" href="' + stepUrl(path.id, firstUnread) + '">Next unread: ' + esc(path.steps[firstUnread].label) + ' &rarr;</a>'
          : '<span></span>';
        botEl.innerHTML =
          '<div class="pn-eyebrow">' + esc(path.title) + ' &middot; learning path</div>' +
          '<div class="pn-big">STEP ' + n + ' OF ' + total + '</div>' +
          '<div class="pn-bar pn-bar-lg"><i style="width:' + pct + '%"></i></div>' +
          '<div class="pn-pct">' + doneCount + ' of ' + total + ' read &middot; ' + pct + '%</div>' +
          note +
          '<div class="pn-steps">' + stepsList + '</div>' +
          '<div class="pn-actions">' + prev + nextBtn + '</div>';
        botEl.className = 'pn-bottom';
      }
    }
  }

  function renderChooser(list) {
      if (!botEl) return;
      botEl.innerHTML =
        '<div class="pn-eyebrow">This page is part of ' + list.length + ' learning paths</div>' +
        '<div class="pn-continue">' + list.map((p) => {
          const i = p.steps.findIndex((st) => st.href === here);
          return '<a href="' + p.steps[i].href + '?p=' + p.id + '&s=' + i + '">Continue: ' + esc(p.title) + ' &rarr;</a>';
        }).join('') + '</div>';
      botEl.className = 'pn-bottom pn-choose';
    }
  })();
</script>

<style is:global>
  /* path nav (JS-injected into #pn-top / #pn-bottom) */
  #pn-top:empty, #pn-bottom:empty { display: none; }
  .pn-bar{height:6px;background:var(--paper-2);border-radius:999px;overflow:hidden}
  .pn-bar i{display:block;height:100%;background:var(--coral);border-radius:999px;transition:width .35s}
  .pn-bar-lg{height:12px;margin:12px 0 8px}

  .pn-top{display:flex;align-items:center;gap:13px;margin:0 0 4px}
  .pn-top .pn-bar{flex:1}
  .pn-top-path{font-family:var(--font-mono);font-size:11.5px;font-weight:700;color:var(--coral);text-decoration:none;white-space:nowrap}
  .pn-top-path:hover{text-decoration:underline}
  .pn-top-step{font-family:var(--font-mono);font-size:11.5px;font-weight:700;color:var(--ink-soft);white-space:nowrap}

  .pn-bottom{margin:34px 0 4px;padding:24px 24px 22px;border:1.5px solid var(--line);border-radius:18px;background:var(--cream);box-shadow:0 12px 30px rgba(40,24,12,.06)}
  .pn-eyebrow{font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:9px}
  .pn-big{font-family:var(--font-display);font-weight:800;font-size:clamp(30px,5vw,42px);letter-spacing:-.02em;line-height:1;color:var(--ink)}
  .pn-pct{font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--coral-deep)}
  .pn-actions{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-top:18px}
  .pn-prev{font-family:var(--font-display);font-weight:700;font-size:14px;color:var(--ink-soft);text-decoration:none;white-space:nowrap}
  .pn-prev:hover{color:var(--ink)}
  .pn-next{font-family:var(--font-display);font-weight:800;font-size:15.5px;color:#fff;background:var(--coral);border-radius:12px;padding:13px 22px;text-decoration:none;box-shadow:0 8px 20px rgba(238,75,43,.28);transition:transform .14s,box-shadow .14s;text-align:center}
  .pn-next:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(238,75,43,.36);background:var(--coral-deep)}

  .pn-done{text-align:center}
  .pn-confetti{font-size:38px;line-height:1}
  .pn-done-h{font-family:var(--font-display);font-weight:800;font-size:30px;letter-spacing:-.02em;margin-top:4px}
  .pn-done-sub{font-size:16px;color:var(--ink-soft);margin:6px 0 0}
  .pn-done .pn-bar{max-width:340px;margin:14px auto 0}
  .pn-continue-h{font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);margin:16px 0 11px}
  .pn-continue{display:flex;flex-wrap:wrap;gap:10px;justify-content:center}
  /* read-progress note + step checklist (real progress, not position) */
  .pn-note{font-size:14px;line-height:1.55;color:var(--ink);margin:13px 0 0;background:rgba(244,180,35,.12);border:1.2px solid rgba(244,132,42,.34);border-radius:11px;padding:11px 14px}
  .pn-steps{display:flex;flex-direction:column;gap:6px;margin:16px 0 2px}
  .pn-step{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:11px;border:1.2px solid var(--line);background:var(--paper-2);text-decoration:none;transition:border-color .14s,background .14s}
  .pn-step:hover{border-color:var(--coral)}
  .pn-step-dot{flex:none;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:12px;font-weight:700;background:var(--cream);border:1.4px solid var(--line);color:var(--ink-soft)}
  .pn-step.is-read .pn-step-dot{background:var(--coral);border-color:var(--coral);color:#fff}
  .pn-step-label{flex:1;font-family:var(--font-display);font-weight:700;font-size:14px;color:var(--ink)}
  .pn-step.is-read .pn-step-label{color:var(--ink-soft)}
  .pn-step.is-here{border-color:var(--coral);background:var(--cream)}
  .pn-step-here,.pn-step-tag{flex:none;font-family:var(--font-mono);font-size:9.5px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;padding:3px 7px;border-radius:6px}
  .pn-step-here{color:var(--coral);background:rgba(238,75,43,.1)}
  .pn-step-tag{color:var(--ink-soft);background:var(--cream);border:1px solid var(--line)}
  .pn-choose{text-align:left}.pn-choose .pn-continue{justify-content:flex-start}
  .pn-continue a{font-family:var(--font-display);font-weight:800;font-size:14px;color:var(--ink);background:var(--paper-2);border:1.2px solid var(--line);border-radius:11px;padding:10px 16px;text-decoration:none;transition:border-color .14s,color .14s}
  .pn-continue a:hover{border-color:var(--coral);color:var(--coral-deep)}
  @media(max-width:560px){.pn-actions{flex-direction:column-reverse;align-items:stretch}.pn-next{padding:14px}.pn-prev{text-align:center}}
</style>
