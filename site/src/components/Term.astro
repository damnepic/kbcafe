---
// <Term slug="commit">commit</Term>  ->  inline link to /dictionary/commit
// The translation-layer plumbing: drop this around any word inside a learning path,
// explainer, or reference page, and a beginner can click it, understand it, and return.
// Gracefully renders plain text if the term has no dictionary entry yet.
import { findTerm } from '../data/dictionary.js';
const { slug } = Astro.props;
const entry = findTerm(slug);
---
{entry ? (
  <a class="kb-term" href={`/dictionary/${entry.slug}`} title={`What is ${entry.term}? (plain-English definition)`}><slot /></a>
) : (
  <slot />
)}
<style>
  .kb-term{
    color: inherit; text-decoration: none; cursor: help;
    border-bottom: 1.5px dotted var(--coral, #EE4B2B);
    transition: background .12s, border-bottom-color .12s;
  }
  .kb-term:hover{ background: rgba(238,75,43,.09); border-bottom-style: solid; }
</style>
